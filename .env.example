# Astro Doge 内置了一组 Vercel API 路由，位于 /api。
# 如果你只把它当作纯静态博客使用，可以完全忽略这个文件。

# 启用任意内置 API 时都建议配置这两项。
# SITE_URL 用于生成回调链接和 CORS 校验。
# GITHUB_TOKEN 建议使用 Fine-grained Token，只授予目标仓库所需权限。
SITE_URL=https://your-domain.com
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# 数据仓库映射。
# 你可以按功能拆成多个仓库，也可以只配置 GITHUB_REPO 作为通用回退仓库。
COMMENTS_REPO=yourname/your-comments-repo
LIKES_REPO=yourname/your-likes-repo
CONTENT_REPO=yourname/your-blog-repo
GITHUB_REPO=yourname/your-shared-repo
CONTENT_BRANCH=main

# 在线发布内容时写入的目录。
THOUGHTS_CONTENT_DIR=src/content/thoughts
ALBUMS_CONTENT_DIR=src/content/albums

# 站点时区，用于在线发布时间、相对时间和点赞日切。
SITE_TIMEZONE=Asia/Shanghai

# 可选：只有 /moments/new 需要浏览器直传图片时才配置。
# 这里填写你自己的上传签名服务地址，例如 Cloudflare R2 Worker。
R2_IMAGE_BASE_URL=https://your-upload-worker.example.com

# 评论和留言板的博主身份校验。
# OWNER_TOKEN 请换成足够随机的私密字符串，不要提交到仓库。
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com
OWNER_TOKEN=replace-this-with-a-random-secret

# 可选：前端用于提示博主身份，方便浏览器里完成校验。
# 如果不想公开邮箱，可以不配置 PUBLIC_OWNER_EMAIL。
PUBLIC_OWNER_NAME=Your Name
PUBLIC_OWNER_EMAIL=you@example.com

# /thoughts/new 和 /moments/new 在线发布使用的口令。
THOUGHT_API_TOKEN=replace-this-with-a-random-secret

# 可选：只读取指定 GitHub 用户创建的评论。
# 配置后，/api/comments 会忽略其他用户创建的 issue/comment。
COMMENT_AUTHOR_LOGIN=your-github-username

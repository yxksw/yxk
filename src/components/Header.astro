---
import Container from '@components/Container.astro'
import Link from '@components/Link.astro'
import ThemeToggle from '@components/ThemeToggle.astro'
import { SITE } from '@consts'

const navItems = [
  { href: '/posts', label: '文章' },
  { href: '/thoughts', label: '碎碎念' },
  { href: '/friends', label: '友链' },
  { href: '/messages', label: '留言板' },
  { href: '/about', label: '关于' },
]

const mobileSheetItems = [
  { href: '/posts', label: '文章', desc: '长文和记录' },
  { href: '/thoughts', label: '碎碎念', desc: '生活流' },
  { href: '/moments', label: '相册', desc: '图像片段' },
  { href: '/messages', label: '留言板', desc: '来聊两句' },
  { href: '/friends', label: '友链', desc: '朋友们' },
  { href: '/about', label: '关于', desc: '关于站点' },
]

const pathname = Astro.url.pathname
const topLevelRoutes = [
  '/posts',
  '/thoughts',
  '/moments',
  '/friends',
  '/messages',
  '/about',
  '/offline',
]
const isArticlePage =
  pathname !== '/' &&
  !topLevelRoutes.some((route) => pathname.startsWith(route))
const isActive = (href: string) => {
  if (href === '/') return pathname === '/'
  if (href === '/posts') return pathname.startsWith('/posts') || isArticlePage
  return pathname.startsWith(href)
}
---

<header id="main-header" data-page-kind={isArticlePage ? 'article' : 'site'}>
  <Container class="!max-w-[820px] py-2.5">
    <div
      class="header-shell flex items-center justify-between gap-3 rounded-xl border border-stone-200/65 bg-white/82 px-3 py-2 shadow-sm shadow-stone-900/[0.025] backdrop-blur-xl dark:border-stone-800 dark:bg-stone-900/45 dark:shadow-black/20"
    >
      <Link
        href="/"
        underline={false}
        class="header-brand group flex shrink-0 items-center"
      >
        <div
          class="text-sm font-semibold tracking-normal text-stone-900 sm:text-base dark:text-stone-100"
        >
          {SITE.NAME}
        </div>
      </Link>
      <nav class="desktop-nav hidden items-center gap-4 md:flex">
        {
          navItems.map((item) => (
            <Link
              href={item.href}
              underline={false}
              class="nav-link"
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </Link>
          ))
        }
      </nav>

      <button
        type="button"
        id="header-nav-toggle"
        class="header-nav-toggle hidden h-8 w-8 items-center justify-center rounded-full text-stone-600 transition-colors hover:bg-stone-100 hover:text-stone-900 dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-stone-50"
        aria-label="展开导航"
        aria-expanded="false"
      >
        <svg
          class="h-4.5 w-4.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="5" y1="7" x2="19" y2="7"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <line x1="5" y1="17" x2="19" y2="17"></line>
        </svg>
      </button>

      <nav class="header-actions flex items-center gap-1.5 sm:gap-2">
        {/* 搜索按钮 */}
        <button
          id="search-toggle"
          class="flex h-8 items-center gap-1.5 rounded-md border border-stone-200/65 bg-white/65 px-2 text-stone-500 transition-colors duration-200 hover:bg-stone-100 hover:text-stone-800 dark:border-stone-800 dark:bg-stone-900/70 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-100"
          aria-label="搜索"
          title="搜索 (Ctrl+K)"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="search-shortcut hidden text-xs text-stone-400 sm:inline"
            >Ctrl K</span
          >
        </button>
        <a
          href="/moments"
          class={`hidden h-8 w-8 items-center justify-center rounded-md border border-stone-200/65 bg-white/65 transition-colors duration-200 hover:bg-stone-100 hover:text-stone-800 md:flex dark:border-stone-800 dark:bg-stone-900/70 dark:hover:bg-stone-800 dark:hover:text-stone-100 ${isActive('/moments') ? 'text-stone-900 dark:text-stone-100' : 'text-stone-500 dark:text-stone-400'}`}
          aria-label="相册"
          title="相册"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="4" y="5" width="16" height="14" rx="2"></rect>
            <circle cx="9" cy="10" r="1.4"></circle>
            <path d="m4 16 4.2-4.2a2 2 0 0 1 2.8 0L16 17"></path>
            <path d="m14 15 1.2-1.2a2 2 0 0 1 2.8 0L20 16"></path>
          </svg>
        </a>
        <ThemeToggle />
        <button
          type="button"
          id="mobile-nav-toggle"
          class="flex h-8 w-8 items-center justify-center rounded-md border border-stone-200/65 bg-white/65 text-stone-500 transition-colors duration-200 hover:bg-stone-100 hover:text-stone-800 active:scale-95 md:hidden dark:border-stone-800 dark:bg-stone-900/70 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-100"
          aria-label="打开导航"
          aria-expanded="false"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="4" y="4" width="6" height="6" rx="1.5"></rect>
            <rect x="14" y="4" width="6" height="6" rx="1.5"></rect>
            <rect x="4" y="14" width="6" height="6" rx="1.5"></rect>
            <rect x="14" y="14" width="6" height="6" rx="1.5"></rect>
          </svg>
        </button>
      </nav>
    </div>
  </Container>
</header>

<div
  id="mobile-nav-sheet"
  class="fixed inset-0 z-[90] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="导航菜单"
>
  <div
    class="mobile-nav-backdrop absolute inset-0 bg-black/5 opacity-0 transition-opacity duration-150 dark:bg-black/20"
  >
  </div>
  <div
    class="mobile-nav-panel absolute top-14 right-3 w-40 translate-y-2 rounded-lg border border-stone-200/70 bg-white/90 p-1.5 opacity-0 shadow-lg shadow-stone-900/[0.06] backdrop-blur-md transition-all duration-150 dark:border-stone-800 dark:bg-stone-950/90 dark:shadow-black/20"
  >
    <nav class="flex flex-col gap-0.5" aria-label="移动端导航">
      {
        mobileSheetItems.map((item) => (
          <a
            href={item.href}
            class={`rounded-md px-2.5 py-2 text-sm transition-colors ${isActive(item.href) ? 'bg-stone-100 text-stone-950 dark:bg-stone-900 dark:text-stone-50' : 'text-stone-600 hover:bg-stone-100/80 hover:text-stone-900 dark:text-stone-400 dark:hover:bg-stone-900 dark:hover:text-stone-100'}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</div>

<!-- 搜索模态框 -->
<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="搜索"
>
  <div
    class="search-container w-full max-w-xl translate-y-4 scale-95 transform rounded-xl bg-white opacity-0 shadow-2xl transition-all duration-200 dark:bg-stone-900"
  >
    <!-- 搜索输入框 -->
    <div
      class="flex items-center border-b border-stone-200 px-4 dark:border-stone-700"
    >
      <svg
        class="mr-3 h-5 w-5 shrink-0 text-stone-400"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章、碎碎念..."
        class="flex-1 bg-transparent py-4 text-sm text-stone-900 placeholder-stone-400 outline-none dark:text-stone-100 dark:placeholder-stone-500"
        autocomplete="off"
      />
      <kbd
        class="hidden rounded bg-stone-100 px-2 py-1 text-xs text-stone-500 sm:inline dark:bg-stone-800 dark:text-stone-400"
        >ESC</kbd
      >
    </div>

    <!-- 搜索结果 -->
    <div id="search-results" class="max-h-80 overflow-y-auto p-2">
      <div
        class="search-hint px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400"
      >
        输入关键词开始搜索
      </div>
    </div>

    <!-- 搜索提示 -->
    <div
      class="hidden items-center justify-between border-t border-stone-200 px-4 py-2 text-xs text-stone-400 sm:flex dark:border-stone-700 dark:text-stone-500"
    >
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1">
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↑</kbd
          >
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↓</kbd
          >
          导航
        </span>
        <span class="flex items-center gap-1">
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↵</kbd
          >
          打开
        </span>
      </div>
      <span>本地搜索</span>
    </div>
  </div>
</div>

<script>
  interface SearchItem {
    title: string
    description?: string
    url: string
    type: 'post' | 'thought'
    date: string
    content?: string
    tags?: string[]
  }

  interface HeaderWindow extends Window {
    __astroDogeHeaderSearchController?: AbortController
    __astroDogeMobileNavController?: AbortController
    __astroDogeHeaderScrollController?: AbortController
  }

  const headerWindow = window as HeaderWindow

  let searchData: SearchItem[] = []
  let selectedIndex = -1
  const HISTORY_KEY = 'search_history'
  const MAX_HISTORY = 5

  // 获取搜索历史
  function getSearchHistory(): string[] {
    try {
      const history = localStorage.getItem(HISTORY_KEY)
      return history ? JSON.parse(history) : []
    } catch {
      return []
    }
  }

  // 保存搜索历史
  function saveSearchHistory(query: string) {
    if (!query || query.length < 2) return
    try {
      let history = getSearchHistory()
      // 移除重复项
      history = history.filter((item) => item !== query)
      // 添加到开头
      history.unshift(query)
      // 限制数量
      history = history.slice(0, MAX_HISTORY)
      localStorage.setItem(HISTORY_KEY, JSON.stringify(history))
    } catch {
      // 忽略存储错误
    }
  }

  // 清除搜索历史
  function clearSearchHistory() {
    try {
      localStorage.removeItem(HISTORY_KEY)
    } catch {
      // 忽略错误
    }
  }

  function escapeHtml(value: string): string {
    return value.replace(
      /[&<>"']/g,
      (char) =>
        ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        })[char] || char,
    )
  }

  async function loadSearchData() {
    if (searchData.length > 0) return

    try {
      const response = await fetch('/api/search.json')
      searchData = await response.json()
    } catch (e) {
      console.error('Failed to load search data:', e)
    }
  }

  function highlightText(text: string, query: string): string {
    const escapedText = escapeHtml(text)
    if (!query) return escapedText
    const escapedQuery = escapeHtml(query)
    const regex = new RegExp(
      `(${escapedQuery.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`,
      'gi',
    )
    return escapedText.replace(
      regex,
      '<mark class="search-highlight">$1</mark>',
    )
  }

  function search(query: string): SearchItem[] {
    if (!query || query.length < 1) return []

    const lowerQuery = query.toLowerCase()
    const results = searchData.filter((item) => {
      let score = 0
      if (item.title.toLowerCase().includes(lowerQuery)) score += 10
      if (item.description?.toLowerCase().includes(lowerQuery)) score += 5
      if (item.content?.toLowerCase().includes(lowerQuery)) score += 3
      if (item.tags?.some((tag) => tag.toLowerCase().includes(lowerQuery)))
        score += 4
      return score > 0
    })

    // Sort by relevance
    results.sort((a, b) => {
      const aTitle = a.title.toLowerCase().includes(lowerQuery) ? 10 : 0
      const bTitle = b.title.toLowerCase().includes(lowerQuery) ? 10 : 0
      const aDesc = a.description?.toLowerCase().includes(lowerQuery) ? 5 : 0
      const bDesc = b.description?.toLowerCase().includes(lowerQuery) ? 5 : 0
      return bTitle + bDesc - (aTitle + aDesc)
    })

    return results.slice(0, 10)
  }

  // 渲染搜索历史
  function renderSearchHistory() {
    const container = document.getElementById('search-results')
    if (!container) return

    const history = getSearchHistory()
    if (history.length === 0) {
      container.innerHTML = `
        <div class="search-hint px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400">
          输入关键词开始搜索
        </div>
      `
      return
    }

    container.innerHTML = `
      <div class="px-3 py-2">
        <div class="mb-2 flex items-center justify-between">
          <span class="text-xs font-medium text-stone-400 dark:text-stone-500">搜索历史</span>
          <button id="clear-history-btn" class="text-xs text-stone-400 hover:text-stone-600 dark:text-stone-500 dark:hover:text-stone-300">
            清除
          </button>
        </div>
        <div class="flex flex-wrap gap-2">
          ${history
            .map(
              (item) => `
            <button class="history-item rounded-full bg-stone-100 px-3 py-1 text-xs text-stone-600 transition-colors hover:bg-stone-200 dark:bg-stone-800 dark:text-stone-400 dark:hover:bg-stone-700">
              ${escapeHtml(item)}
            </button>
          `,
            )
            .join('')}
        </div>
      </div>
    `

    // 绑定清除按钮
    document
      .getElementById('clear-history-btn')
      ?.addEventListener('click', () => {
        clearSearchHistory()
        renderSearchHistory()
      })

    // 绑定历史项点击
    container.querySelectorAll('.history-item').forEach((item) => {
      item.addEventListener('click', () => {
        const input = document.getElementById(
          'search-input',
        ) as HTMLInputElement
        if (input) {
          input.value = item.textContent?.trim() || ''
          input.dispatchEvent(new Event('input'))
        }
      })
    })
  }

  function renderResults(results: SearchItem[], query: string) {
    const container = document.getElementById('search-results')
    if (!container) return

    if (results.length === 0 && query) {
      container.innerHTML = `
        <div class="px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400">
          没有找到 "<span class="font-medium">${escapeHtml(query)}</span>" 的相关结果
        </div>
      `
      return
    }

    if (results.length === 0) {
      renderSearchHistory()
      return
    }

    container.innerHTML = results
      .map(
        (item, index) => `
        <a
          href="${escapeHtml(item.url)}"
          class="search-result-item block rounded-lg px-3 py-2.5 transition-colors hover:bg-stone-100 dark:hover:bg-stone-800 ${index === selectedIndex ? 'bg-stone-100 dark:bg-stone-800' : ''}"
          data-index="${index}"
        >
          <div class="flex items-center gap-2">
            <span class="shrink-0 rounded px-1.5 py-0.5 text-xs ${item.type === 'post' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-300' : 'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-300'}">
              ${item.type === 'post' ? '文章' : '碎碎念'}
            </span>
            <span class="flex-1 truncate text-sm font-medium text-stone-800 dark:text-stone-200">
              ${highlightText(item.title, query)}
            </span>
          </div>
          ${item.description ? `<p class="mt-1 truncate text-xs text-stone-500 dark:text-stone-400">${highlightText(item.description, query)}</p>` : ''}
        </a>
      `,
      )
      .join('')

    selectedIndex = -1
  }

  function updateSelection(newIndex: number) {
    const items = document.querySelectorAll('.search-result-item')
    if (items.length === 0) return

    // Clamp index
    if (newIndex < 0) newIndex = items.length - 1
    if (newIndex >= items.length) newIndex = 0

    // Update classes
    items.forEach((item, i) => {
      if (i === newIndex) {
        item.classList.add('bg-stone-100', 'dark:bg-stone-800')
      } else {
        item.classList.remove('bg-stone-100', 'dark:bg-stone-800')
      }
    })

    selectedIndex = newIndex

    // Scroll into view
    const selectedItem = items[newIndex] as HTMLElement
    selectedItem?.scrollIntoView({ block: 'nearest' })
  }

  function setupSearch() {
    const modal = document.getElementById('search-modal')
    const toggle = document.getElementById('search-toggle')
    const input = document.getElementById('search-input') as HTMLInputElement
    const container = modal?.querySelector('.search-container')

    headerWindow.__astroDogeHeaderSearchController?.abort()

    if (!modal || !toggle || !input || !container) return

    const controller = new AbortController()
    headerWindow.__astroDogeHeaderSearchController = controller
    const { signal } = controller
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    const openModal = async () => {
      await loadSearchData()
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      requestAnimationFrame(() => {
        container.classList.remove('opacity-0', 'scale-95', 'translate-y-4')
        container.classList.add('opacity-100', 'scale-100', 'translate-y-0')
        input.focus()
      })
    }

    const closeModal = () => {
      container.classList.add('opacity-0', 'scale-95', 'translate-y-4')
      container.classList.remove('opacity-100', 'scale-100', 'translate-y-0')

      if (closeTimer) clearTimeout(closeTimer)
      closeTimer = setTimeout(() => {
        modal.classList.add('hidden')
        modal.classList.remove('flex')
        input.value = ''
        renderSearchHistory()
        selectedIndex = -1
      }, 200)
    }

    signal.addEventListener(
      'abort',
      () => {
        if (closeTimer) clearTimeout(closeTimer)
      },
      { once: true },
    )

    // Toggle button click
    toggle.addEventListener('click', openModal, { signal })

    // Click outside to close
    modal.addEventListener(
      'click',
      (e) => {
        if (e.target === modal) {
          closeModal()
        }
      },
      { signal },
    )

    // Keyboard shortcuts
    document.addEventListener(
      'keydown',
      (e) => {
        // Ctrl/Cmd + K to open
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault()
          if (modal.classList.contains('hidden')) {
            openModal()
          } else {
            closeModal()
          }
        }

        // ESC to close
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal()
        }

        // Arrow keys and Enter when modal is open
        if (!modal.classList.contains('hidden')) {
          const items = document.querySelectorAll('.search-result-item')

          if (e.key === 'ArrowDown') {
            e.preventDefault()
            updateSelection(selectedIndex + 1)
          } else if (e.key === 'ArrowUp') {
            e.preventDefault()
            updateSelection(selectedIndex - 1)
          } else if (e.key === 'Enter' && selectedIndex >= 0) {
            e.preventDefault()
            const selectedItem = items[selectedIndex] as HTMLAnchorElement
            if (selectedItem) {
              // 保存到搜索历史
              const query = input.value.trim()
              saveSearchHistory(query)
              window.location.href = selectedItem.href
            }
          }
        }
      },
      { signal },
    )

    // Search input
    let debounceTimer: ReturnType<typeof setTimeout>
    input.addEventListener(
      'input',
      () => {
        clearTimeout(debounceTimer)
        debounceTimer = setTimeout(() => {
          const query = input.value.trim()
          const results = search(query)
          renderResults(results, query)
        }, 150)
      },
      { signal },
    )

    signal.addEventListener(
      'abort',
      () => {
        clearTimeout(debounceTimer)
      },
      { once: true },
    )

    // 点击搜索结果时保存历史
    const resultsContainer = document.getElementById('search-results')
    resultsContainer?.addEventListener(
      'click',
      (e) => {
        const target = e.target as HTMLElement
        const link = target.closest('.search-result-item')
        if (link) {
          const query = input.value.trim()
          saveSearchHistory(query)
        }
      },
      { signal },
    )
  }

  function setupMobileNavSheet() {
    const toggles = [document.getElementById('mobile-nav-toggle')].filter(
      Boolean,
    ) as HTMLElement[]
    const sheet = document.getElementById('mobile-nav-sheet')
    const backdrop = sheet?.querySelector('.mobile-nav-backdrop')
    const panel = sheet?.querySelector('.mobile-nav-panel')

    headerWindow.__astroDogeMobileNavController?.abort()

    if (toggles.length === 0 || !sheet || !panel) return

    const controller = new AbortController()
    headerWindow.__astroDogeMobileNavController = controller
    const { signal } = controller
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    const openSheet = () => {
      sheet.classList.remove('hidden')
      toggles.forEach((toggle) => toggle.setAttribute('aria-expanded', 'true'))
      requestAnimationFrame(() => {
        backdrop?.classList.add('opacity-100')
        backdrop?.classList.remove('opacity-0')
        panel.classList.remove('translate-y-2', 'opacity-0')
        panel.classList.add('translate-y-0', 'opacity-100')
      })
    }

    const closeSheet = () => {
      toggles.forEach((toggle) => toggle.setAttribute('aria-expanded', 'false'))
      backdrop?.classList.remove('opacity-100')
      backdrop?.classList.add('opacity-0')
      panel.classList.add('translate-y-2', 'opacity-0')
      panel.classList.remove('translate-y-0', 'opacity-100')
      if (closeTimer) clearTimeout(closeTimer)
      closeTimer = setTimeout(() => {
        sheet.classList.add('hidden')
      }, 180)
    }

    signal.addEventListener(
      'abort',
      () => {
        if (closeTimer) clearTimeout(closeTimer)
      },
      { once: true },
    )

    toggles.forEach((toggle) => {
      toggle.addEventListener(
        'click',
        () => {
          if (sheet.classList.contains('hidden')) openSheet()
          else closeSheet()
        },
        { signal },
      )
    })
    backdrop?.addEventListener('click', closeSheet, { signal })
    sheet.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeSheet, { signal })
    })
    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'Escape' && !sheet.classList.contains('hidden')) {
          closeSheet()
        }
      },
      { signal },
    )
  }

  function setupHeaderScroll() {
    const header = document.getElementById('main-header')
    headerWindow.__astroDogeHeaderScrollController?.abort()

    if (!header) {
      document.body.classList.remove('article-page')
      return
    }

    const controller = new AbortController()
    headerWindow.__astroDogeHeaderScrollController = controller
    const { signal } = controller

    document.body.classList.toggle(
      'article-page',
      header.dataset.pageKind === 'article',
    )

    const headerNavToggle = document.getElementById('header-nav-toggle')
    const mobileQuery = window.matchMedia('(max-width: 639px)')
    let lastY = window.scrollY
    let collapsed = false
    let hidden = false
    let ticking = false

    const update = () => {
      const currentY = Math.max(window.scrollY, 0)
      const delta = currentY - lastY
      const isMobile = mobileQuery.matches

      header.classList.toggle('is-compact', currentY > 24)

      if (isMobile) {
        collapsed = false
        if (currentY < 80) {
          hidden = false
        } else if (delta > 6) {
          hidden = true
        } else if (delta < -6) {
          hidden = false
        }
      } else {
        hidden = false
        if (currentY < 80) {
          collapsed = false
        } else if (delta > 6) {
          collapsed = true
        } else if (delta < -6) {
          collapsed = false
        }
      }

      header.classList.toggle('is-collapsed', collapsed)
      header.classList.toggle('is-scroll-hidden', hidden)
      headerNavToggle?.setAttribute(
        'aria-expanded',
        collapsed ? 'false' : 'true',
      )
      lastY = currentY
      ticking = false
    }

    headerNavToggle?.addEventListener(
      'click',
      () => {
        collapsed = false
        hidden = false
        lastY = Math.max(window.scrollY, 0)
        header.classList.toggle('is-compact', lastY > 24)
        header.classList.remove('is-collapsed', 'is-scroll-hidden')
        headerNavToggle.setAttribute('aria-expanded', 'true')
      },
      { signal },
    )

    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return
        ticking = true
        requestAnimationFrame(update)
      },
      { passive: true, signal },
    )
    update()
  }

  // Initialize
  setupSearch()
  setupMobileNavSheet()
  setupHeaderScroll()

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', () => {
    setupSearch()
    setupMobileNavSheet()
    setupHeaderScroll()
  })
</script>

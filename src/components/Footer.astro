---
import Container from '@components/Container.astro'
import { SITE, SOCIALS } from '@consts'

const githubHref =
  SOCIALS.find((social) => social.NAME.toLowerCase() === 'github')?.HREF ||
  'https://github.com/username'
---

<footer class="pt-6 pb-8">
  <Container class="!max-w-3xl">
    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-stone-200/70 py-6 text-xs text-stone-500 sm:flex-row dark:border-stone-800 dark:text-stone-400"
    >
      <div class="flex items-center gap-2">
        <span>&copy; {new Date().getFullYear()} {SITE.NAME}</span>
        <span class="hidden sm:inline">·</span>
        <span class="hidden sm:inline">Built with Astro</span>
      </div>

      <div class="flex items-center gap-4">
        <a
          href={githubHref}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
          aria-label="GitHub"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0C5.37 0 0 5.5 0 12.3c0 5.44 3.44 10.04 8.21 11.67.6.11.82-.27.82-.59 0-.29-.01-1.06-.02-2.08-3.34.74-4.04-1.65-4.04-1.65-.55-1.42-1.33-1.8-1.33-1.8-1.09-.76.08-.75.08-.75 1.2.09 1.84 1.27 1.84 1.27 1.07 1.88 2.81 1.34 3.49 1.02.11-.79.42-1.34.76-1.65-2.67-.31-5.47-1.37-5.47-6.09 0-1.35.47-2.45 1.24-3.31-.12-.31-.54-1.56.12-3.26 0 0 1.01-.33 3.3 1.26.96-.27 1.98-.4 3-.41 1.02.01 2.05.14 3 .41 2.29-1.59 3.3-1.26 3.3-1.26.66 1.7.24 2.95.12 3.26.77.86 1.24 1.96 1.24 3.31 0 4.73-2.81 5.77-5.49 6.08.43.38.82 1.13.82 2.29 0 1.65-.02 2.98-.02 3.39 0 .33.22.71.83.59A12.23 12.23 0 0 0 24 12.3C24 5.5 18.63 0 12 0Z"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${SITE.EMAIL}`}
          class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
          aria-label="Email"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect>
            <path d="M3 7.5 12 13 21 7.5"></path>
          </svg>
        </a>
        <a
          href="/rss.xml"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-stone-900 dark:hover:text-stone-100"
          aria-label="RSS"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M6.18 17.82A2.18 2.18 0 1 1 1.82 17.82 2.18 2.18 0 0 1 6.18 17.82ZM2 9.8v3.1a9.1 9.1 0 0 1 9.1 9.1h3.1A12.2 12.2 0 0 0 2 9.8ZM2 2v3.1A16.9 16.9 0 0 1 18.9 22H22A20 20 0 0 0 2 2Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</footer>

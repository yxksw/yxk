---
// 图片灯箱组件 - 点击图片查看全图
---

<!-- 灯箱 overlay 容器 -->
<div id="lightbox-overlay" class="lightbox-overlay" style="display: none;">
  <button class="lightbox-close" aria-label="关闭">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <img src="" alt="" />
</div>

<script>
  interface LightboxWindow extends Window {
    __astroDogeLightboxController?: AbortController
  }

  const lightboxWindow = window as LightboxWindow

  function initImageLightbox() {
    const overlay = document.getElementById(
      'lightbox-overlay',
    ) as HTMLDivElement | null
    lightboxWindow.__astroDogeLightboxController?.abort()

    if (!overlay) return

    const controller = new AbortController()
    const { signal } = controller
    lightboxWindow.__astroDogeLightboxController = controller

    const lightboxImg = overlay.querySelector('img') as HTMLImageElement
    const closeBtn = overlay.querySelector('.lightbox-close')
    let closeTimer: ReturnType<typeof setTimeout> | null = null

    // 关闭灯箱函数
    function closeLightbox() {
      overlay!.classList.remove('active')
      if (closeTimer) clearTimeout(closeTimer)
      closeTimer = setTimeout(() => {
        overlay!.style.display = 'none'
      }, 300)
    }

    signal.addEventListener(
      'abort',
      () => {
        if (closeTimer) clearTimeout(closeTimer)
      },
      { once: true },
    )

    // 点击 overlay 关闭
    overlay.addEventListener('click', closeLightbox, { signal })
    closeBtn?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        closeLightbox()
      },
      { signal },
    )

    // ESC 键关闭
    function handleEsc(e: KeyboardEvent) {
      if (e.key === 'Escape' && overlay!.classList.contains('active')) {
        closeLightbox()
      }
    }
    document.addEventListener('keydown', handleEsc, { signal })

    // 滚动时关闭
    function handleScroll() {
      if (overlay!.classList.contains('active')) {
        closeLightbox()
      }
    }
    window.addEventListener('scroll', handleScroll, { signal })

    // 统一绑定灯箱的辅助函数
    function bindLightbox(img: HTMLImageElement) {
      img.style.cursor = 'zoom-in'
      img.addEventListener(
        'click',
        (e) => {
          e.preventDefault()
          e.stopPropagation()
          lightboxImg.src = img.src
          lightboxImg.alt = img.alt
          overlay!.style.display = 'flex'
          requestAnimationFrame(() => {
            overlay!.classList.add('active')
          })
        },
        { signal },
      )
    }

    // 为所有 article 中的图片添加点击事件
    const articles = document.querySelectorAll('article')
    articles.forEach((article) => {
      article.querySelectorAll('img').forEach(bindLightbox)
    })

    // 封面图
    document
      .querySelectorAll<HTMLImageElement>('.post-cover img')
      .forEach(bindLightbox)
  }

  // 页面加载时初始化
  document.addEventListener('DOMContentLoaded', initImageLightbox)
  document.addEventListener('astro:after-swap', initImageLightbox)

  // 立即执行一次
  initImageLightbox()
</script>

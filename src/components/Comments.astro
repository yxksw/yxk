                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    ${nameHtml}
                    ${ownerBadge}
                    ${replyToHtml}
                  </div>
                  <div class="text-stone-400 mt-0.5 flex items-center gap-2 ${timeSize} dark:text-stone-500">
                    <time datetime="${comment.createdAt}" title="${new Date(comment.createdAt).toLocaleString('zh-CN')}">
                      ${formatRelativeTime(comment.createdAt)}
                    </time>
                    ${getUserAgentInfo(comment.userAgent || '')}
                  </div>
                </div>
              </div>
            </div>
            <div class="message-content prose prose-sm max-w-none ${lineClamp} dark:prose-invert">
              ${contentHtml}
            </div>
          </div>
        `
      }

      return `
        <article class="comment-card group relative rounded-lg border p-4 transition" data-id="${comment.id}" data-name="${comment.name}"${comment.isPending ? ' data-pending="true"' : ''}>
          ${featuredMark}
          <div class="mb-3 ${comment.featured ? 'pr-8' : ''}">
            <div class="flex items-center gap-3">
              <div class="relative shrink-0">
                <img alt="${comment.name}" referrerpolicy="no-referrer" loading="lazy" width="36" height="36"
                  class="comment-avatar rounded-full object-cover ${avatarSize}"
                  src="${comment.avatar}" />
                ${getOwnerAvatarMark(comment.isOwner)}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  ${nameHtml}
                  ${ownerBadge}
                  ${replyToHtml}
                </div>
                <div class="text-stone-400 mt-0.5 flex items-center gap-2 ${timeSize} dark:text-stone-500">
                  <time datetime="${comment.createdAt}" title="${new Date(comment.createdAt).toLocaleString('zh-CN')}">
                    ${formatRelativeTime(comment.createdAt)}
                  </time>
                  ${getUserAgentInfo(comment.userAgent || '')}
                </div>
              </div>
            </div>
          </div>
          <div class="relative">
            <div class="message-content prose prose-sm max-w-none ${lineClamp} dark:prose-invert">
              ${contentHtml}
            </div>
          </div>
          <div class="mt-3 flex items-center justify-between border-t border-stone-200 pt-3 dark:border-stone-700">
            ${
              hasReplies
                ? `
              <button type="button" class="toggle-replies-btn inline-flex items-center justify-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-stone-500 transition-all hover:bg-stone-100 hover:text-stone-700 active:scale-90 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200" data-target="${comment.id}" data-expanded="false">
                <span class="toggle-text">展开回复 (${repliesCount})</span>
                <svg class="toggle-icon h-3.5 w-3.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"></polyline>
                </svg>
              </button>
            `
                : '<div></div>'
            }
            ${
              comment.isPending
                ? `<button type="button" class="reply-btn inline-flex items-center justify-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-stone-400 transition-all cursor-not-allowed opacity-50 dark:text-stone-500" disabled title="评论正在同步中，请稍候...">
                  回复
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 14 4 9 9 4"></polyline>
                    <path d="M20 20v-7a4 4 0 0 0-4-4H4"></path>
                  </svg>
                </button>`
                : `<button type="button" class="reply-btn inline-flex items-center justify-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-stone-500 transition-all hover:bg-stone-100 hover:text-stone-700 active:scale-90 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200">
                  回复
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 14 4 9 9 4"></polyline>
                    <path d="M20 20v-7a4 4 0 0 0-4-4H4"></path>
                  </svg>
                </button>`
            }
          </div>
          <div class="reply-form-container"></div>
          ${repliesHtml}
        </article>
      `
    }


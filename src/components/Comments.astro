---
// 自定义评论组件
// 使用 GitHub Issues 存储，支持 Gravatar 头像、表情、Markdown 和剧透语法
// 现代化卡片式设计

interface Props {
  slug: string
  title: string
  variant?: 'default' | 'guestbook'
}

const { slug, title, variant = 'default' } = Astro.props
const isGuestbook = variant === 'guestbook'
const publicOwnerName = import.meta.env.PUBLIC_OWNER_NAME || ''
const publicOwnerEmail = import.meta.env.PUBLIC_OWNER_EMAIL || ''
---

<section
  class:list={[
    'comments-section',
    isGuestbook && 'comments-section--guestbook',
  ]}
  data-slug={slug}
  data-title={title}
  data-owner-name={publicOwnerName}
  data-owner-email={publicOwnerEmail}
>
  <!-- 评论表单 -->
  <form
    id="comment-form"
    class:list={[
      isGuestbook
        ? 'border-y border-stone-200/70 py-4 dark:border-stone-800'
        : 'rounded-lg border border-stone-200 p-4 dark:border-stone-700',
    ]}
  >
    <input
      type="text"
      name="_gotcha"
      class="hidden"
      tabindex="-1"
      autocomplete="off"
    />
    <!-- 用户信息区域 - 三列布局 -->
    <div
      class="no-focus mb-2 grid grid-cols-1 gap-1 border-b border-stone-200 pb-2 sm:grid-cols-3 sm:gap-2 dark:border-stone-700"
    >
      <div class="flex items-center gap-2">
        <label
          for="comment-name"
          class="shrink-0 text-[16px] text-stone-500 sm:text-sm dark:text-stone-400"
          >名称:</label
        >
        <input
          id="comment-name"
          name="name"
          type="text"
          maxlength="50"
          placeholder="必填，用于展示身份"
          required
          class="flex-1 border-0 bg-transparent text-[16px] text-stone-900 outline-none placeholder:text-stone-400 sm:text-sm dark:text-stone-100 dark:placeholder:text-stone-500"
        />
      </div>
      <div class="relative flex items-center gap-2">
        <label
          for="comment-email"
          class="shrink-0 text-[16px] text-stone-500 sm:text-sm dark:text-stone-400"
          >邮箱:</label
        >
        <input
          id="comment-email"
          name="email"
          type="email"
          placeholder="可选，用于头像和通知"
          class="flex-1 border-0 bg-transparent pr-8 text-[16px] text-stone-900 outline-none placeholder:text-stone-400 sm:text-sm dark:text-stone-100 dark:placeholder:text-stone-500"
        />
        <div
          class="pointer-events-none absolute top-1/2 right-0 -translate-y-1/2"
        >
          <img
            id="avatar-preview"
            alt="头像预览"
            loading="lazy"
            width="24"
            height="24"
            class="h-6 w-6 rounded-full border border-stone-300 dark:border-stone-600"
            src="https://weavatar.com/avatar/?d=mp&s=80"
          />
        </div>
      </div>
      <div class="flex items-center gap-2">
        <label
          for="comment-website"
          class="shrink-0 text-[16px] text-stone-500 sm:text-sm dark:text-stone-400"
          >网站:</label
        >
        <input
          id="comment-website"
          name="website"
          type="url"
          placeholder="可选，用于引导访问"
          class="flex-1 border-0 bg-transparent text-[16px] text-stone-900 outline-none placeholder:text-stone-400 sm:text-sm dark:text-stone-100 dark:placeholder:text-stone-500"
        />
      </div>
    </div>

    <!-- 评论内容 -->
    <textarea
      id="comment-content"
      name="content"
      maxlength="1200"
      rows="5"
      placeholder="既然来了，不妨留个言再走吧..."
      required
      spellcheck="false"
      class="no-focus w-full resize-y border-0 bg-transparent text-[16px] leading-relaxed text-stone-900 outline-none placeholder:text-stone-400 dark:text-stone-100 dark:placeholder:text-stone-500"
    ></textarea>

    <!-- 底部工具栏 -->
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-2 text-stone-400 dark:text-stone-500">
        <!-- 表情按钮 -->
        <div class="relative flex items-center">
          <button
            type="button"
            id="emoji-btn"
            aria-label="选择表情"
            class="inline-flex items-center justify-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-stone-500 transition-all hover:bg-stone-100 hover:text-stone-700 active:scale-90 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200"
          >
            <svg
              class="h-3.5 w-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
              <line x1="9" y1="9" x2="9.01" y2="9"></line>
              <line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
            表情
          </button>
          <!-- 表情选择器 -->
          <div
            id="emoji-picker"
            class="emoji-picker absolute bottom-full left-0 z-20 mb-2 hidden w-80 rounded-lg border border-stone-200 bg-white p-1 shadow-xl sm:w-96 dark:border-stone-700 dark:bg-stone-800"
          >
            <div id="emoji-content" class="max-h-60 overflow-y-auto p-1"></div>
            <div
              class="mt-1 border-t border-stone-100 pt-1 dark:border-stone-700/50"
            >
              <div
                id="emoji-tabs"
                class="flex flex-nowrap gap-1 overflow-x-auto px-1 pb-1"
              >
              </div>
            </div>
          </div>
        </div>
        <span class="hidden text-xs sm:inline"
          >支持 Markdown、预设表情、剧透语法，如 || 剧透内容 ||</span
        >
      </div>

      <div class="flex items-center gap-2">
        <span
          id="char-count-wrapper"
          class="hidden text-xs text-stone-400 sm:inline dark:text-stone-500"
        >
          <span id="char-count">0</span> / 1200
        </span>
        <button
          type="submit"
          id="submit-btn"
          class="inline-flex items-center justify-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium text-stone-500 transition-all hover:bg-stone-100 hover:text-stone-700 active:scale-90 disabled:cursor-not-allowed disabled:opacity-50 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200"
        >
          <span id="submit-text">提交留言</span>
          <svg
            id="submit-icon"
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
          <svg
            id="submit-spinner"
            class="hidden h-3.5 w-3.5 animate-spin"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </form>

  <!-- 评论列表 -->
  <div id="comments-container" class={isGuestbook ? 'mt-10' : 'mt-12 sm:mt-16'}>
    <h2
      id="comments-count"
      class="mb-6 hidden font-medium text-stone-900 sm:text-lg dark:text-stone-100"
    >
      大家在聊 (<span id="count-number">0</span>)
    </h2>

    <div id="comments-loading" class="py-12 text-center">
      <p class="animate-pulse text-sm text-stone-500 dark:text-stone-400">
        加载评论中...
      </p>
    </div>

    <div id="comments-list" class="hidden space-y-4"></div>

    <div id="comments-empty" class="hidden">
      <div class="mt-24 flex flex-col items-center justify-center rounded-lg">
        <div class="mb-4 rounded-full bg-stone-50 p-4 dark:bg-stone-800/50">
          <svg
            class="h-8 w-8 text-stone-300 dark:text-stone-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"
            ></path>
          </svg>
        </div>
        <p class="text-sm font-medium text-stone-600 dark:text-stone-400">
          还没有人留言
        </p>
        <p class="mt-1 text-xs text-stone-400 dark:text-stone-500">
          快来抢占沙发
        </p>
      </div>
    </div>

    <div id="comments-error" class="hidden">
      <div
        class="flex items-center gap-3 rounded-lg border border-stone-200 bg-stone-50 px-4 py-3 dark:border-stone-700 dark:bg-stone-900/50"
      >
        <svg
          class="h-5 w-5 shrink-0 text-stone-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="flex-1 text-sm text-stone-600 dark:text-stone-400"
          >加载评论时出错了</span
        >
        <button
          id="retry-load"
          class="rounded-lg border border-stone-200 bg-white px-3 py-1 text-xs font-medium text-stone-600 transition-colors hover:bg-stone-50 hover:text-stone-900 dark:border-stone-700 dark:bg-stone-800 dark:text-stone-300 dark:hover:bg-stone-700"
          >重试</button
        >
      </div>
    </div>
  </div>
</section>

<script>
  interface Comment {
    id: number
    name: string
    avatar: string
    website?: string
    content: string
    createdAt: string
    userAgent?: string
    replyTo?: {
      id: number
      name: string
    }
    isOwner?: boolean
    featured?: boolean
    replies?: Comment[]
    isPending?: boolean // 标记为待确认的本地评论
  }

  interface PendingComment {
    slug: string
    id: number
    name: string
    email?: string
    website?: string
    content: string
    createdAt: string
    replyToId?: number
    replyToName?: string
    submittedAt: number // 提交时间戳
    isOwner?: boolean
    featured?: boolean
    userAgent?: string
  }

  const PENDING_COMMENTS_KEY = 'pending_comments'
  const PENDING_TIMEOUT = 5 * 60 * 1000 // 5 分钟超时

  interface EmojiPack {
    type: string
    name: string
    size?: number
    items: Record<string, string>
  }

  type EmojisConfig = Record<string, EmojiPack>

  let emojisConfigPromise: Promise<EmojisConfig> | null = null

  interface CommentsWindow extends Window {
    __astroDogeCommentsController?: AbortController
  }

  const commentsWindow = window as CommentsWindow

  function loadEmojisConfig(): Promise<EmojisConfig> {
    if (!emojisConfigPromise) {
      emojisConfigPromise = fetch('/emojis.json')
        .then((response) => (response.ok ? response.json() : {}))
        .catch((error) => {
          console.error('Failed to load emojis:', error)
          return {}
        })
    }

    return emojisConfigPromise
  }

  const STORAGE_KEY = 'blog-comment-user'
  const GRAVATAR_DEBOUNCE = 800

  interface StoredUserInfo {
    name: string
    email: string
    website?: string
  }

  interface CommentPayload {
    slug?: string
    title?: string
    name: string
    email?: string
    website?: string
    content: string
    replyToId?: string
    replyToName?: string
    isOwner?: boolean
    ownerToken?: string
    userAgent?: string
    _gotcha?: string
  }

  // ============================================================
  // 待确认评论缓存管理
  // ============================================================

  function getPendingComments(): PendingComment[] {
    try {
      const data = localStorage.getItem(PENDING_COMMENTS_KEY)
      return data ? JSON.parse(data) : []
    } catch {
      return []
    }
  }

  function savePendingComments(comments: PendingComment[]): void {
    localStorage.setItem(PENDING_COMMENTS_KEY, JSON.stringify(comments))
  }

  function addPendingComment(comment: PendingComment): void {
    const comments = getPendingComments()
    comments.push(comment)
    savePendingComments(comments)
  }

  function removePendingComment(id: number): void {
    const comments = getPendingComments().filter((c) => c.id !== id)
    savePendingComments(comments)
  }

  function cleanExpiredPendingComments(): void {
    const now = Date.now()
    const comments = getPendingComments().filter(
      (c) => now - c.submittedAt < PENDING_TIMEOUT,
    )
    savePendingComments(comments)
  }

  // 检查远程评论是否匹配本地待确认评论
  function matchPendingComment(
    remote: Comment,
    pending: PendingComment,
  ): boolean {
    // 通过名称和内容匹配（内容前50字符）
    const contentMatch =
      remote.content.slice(0, 50) === pending.content.slice(0, 50)
    const nameMatch = remote.name === pending.name
    // 时间差在 10 分钟内
    const timeDiff = Math.abs(
      new Date(remote.createdAt).getTime() -
        new Date(pending.createdAt).getTime(),
    )
    const timeMatch = timeDiff < 10 * 60 * 1000
    return nameMatch && contentMatch && timeMatch
  }

  // 将待确认评论转换为 Comment 对象
  function pendingToComment(pending: PendingComment): Comment {
    const md5Hash = pending.email ? md5(pending.email.toLowerCase().trim()) : ''
    return {
      id: pending.id,
      name: pending.name,
      avatar: pending.email
        ? `https://weavatar.com/avatar/${md5Hash}?s=80&d=identicon`
        : 'https://weavatar.com/avatar/?d=mp',
      website: pending.website,
      content: pending.content,
      createdAt: pending.createdAt,
      userAgent: pending.userAgent,
      replyTo: pending.replyToId
        ? {
            id: pending.replyToId,
            name: pending.replyToName || '',
          }
        : undefined,
      isOwner: pending.isOwner,
      featured: pending.featured,
      isPending: true,
    }
  }

  // 合并远程评论和本地待确认评论
  function mergeWithPendingComments(
    remoteComments: Comment[],
    currentSlug: string,
  ): Comment[] {
    // 清理过期的待确认评论
    cleanExpiredPendingComments()

    const pendingComments = getPendingComments().filter(
      (p) => p.slug === currentSlug,
    )
    if (pendingComments.length === 0) return remoteComments

    // 检查哪些待确认评论已经在远程存在
    const remainingPending: PendingComment[] = []

    for (const pending of pendingComments) {
      let found = false

      // 检查顶层评论
      for (const remote of remoteComments) {
        if (matchPendingComment(remote, pending)) {
          found = true
          removePendingComment(pending.id)
          break
        }
        // 检查回复
        if (remote.replies) {
          for (const reply of remote.replies) {
            if (matchPendingComment(reply, pending)) {
              found = true
              removePendingComment(pending.id)
              break
            }
          }
        }
        if (found) break
      }

      if (!found) {
        remainingPending.push(pending)
      }
    }

    // 将剩余的待确认评论合并到列表中
    const result = [...remoteComments]

    for (const pending of remainingPending) {
      const pendingComment = pendingToComment(pending)

      if (pending.replyToId) {
        // 是回复，找到父评论并添加
        for (const comment of result) {
          if (comment.id === pending.replyToId) {
            if (!comment.replies) comment.replies = []
            comment.replies.push(pendingComment)
            // 按时间排序
            comment.replies.sort(
              (a, b) =>
                new Date(a.createdAt).getTime() -
                new Date(b.createdAt).getTime(),
            )
            break
          }
        }
      } else {
        // 是顶层评论，添加到开头
        result.unshift(pendingComment)
      }
    }

    return result
  }

  // 解析表情语法 :packname_emojiname: 为图片
  function parseEmojis(text: string, emojisConfig: EmojisConfig): string {
    return text.replace(
      /:([a-zA-Z0-9_]+)_([a-zA-Z0-9\u4e00-\u9fa5]+):/g,
      (match, packName, emojiName) => {
        const pack = emojisConfig[packName]
        if (pack && pack.items[emojiName]) {
          const url = pack.items[emojiName]
          const size = pack.size || 24
          if (pack.type === 'image') {
            return `<img class="emoji" src="${url}" alt="${emojiName}" title="${emojiName}" width="${size}" height="${size}" loading="lazy" referrerpolicy="no-referrer" />`
          } else {
            return pack.items[emojiName]
          }
        }
        return match
      },
    )
  }

  // 简单的 Markdown 解析器（包含剧透语法）
  function parseMarkdown(text: string, emojisConfig: EmojisConfig): string {
    let html = text
      // 转义 HTML
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      // 剧透语法 || text ||
      .replace(
        /\|\|([^|]+)\|\|/g,
        '<span class="spoiler" onclick="this.classList.toggle(\'revealed\')" title="点击查看剧透">$1</span>',
      )
      // 图片 ![alt](url)
      .replace(
        /!\[([^\]]*)\]\(([^)]+)\)/g,
        '<img src="$2" alt="$1" class="emoji" loading="lazy" />',
      )
      // 链接 [text](url)
      .replace(
        /\[([^\]]+)\]\(([^)]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener noreferrer" class="comment-link">$1</a>',
      )
      // 粗体 **text**
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      // 斜体 *text*
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      // 行内代码 `code`
      .replace(/`([^`]+)`/g, '<code class="inline-code">$1</code>')
      // 换行
      .replace(/\n/g, '<br>')

    // 解析表情语法
    html = parseEmojis(html, emojisConfig)

    return html
  }

  // MD5 实现（简化版，用于 Gravatar）
  function md5(string: string): string {
    function rotateLeft(value: number, shift: number): number {
      return (value << shift) | (value >>> (32 - shift))
    }

    function addUnsigned(x: number, y: number): number {
      const x4 = x & 0x80000000
      const y4 = y & 0x80000000
      const x8 = x & 0x40000000
      const y8 = y & 0x40000000
      const result = (x & 0x3fffffff) + (y & 0x3fffffff)
      if (x8 & y8) return result ^ 0x80000000 ^ x4 ^ y4
      if (x8 | y8) {
        if (result & 0x40000000) return result ^ 0xc0000000 ^ x4 ^ y4
        else return result ^ 0x40000000 ^ x4 ^ y4
      } else {
        return result ^ x4 ^ y4
      }
    }

    function f(x: number, y: number, z: number): number {
      return (x & y) | (~x & z)
    }
    function g(x: number, y: number, z: number): number {
      return (x & z) | (y & ~z)
    }
    function h(x: number, y: number, z: number): number {
      return x ^ y ^ z
    }
    function i(x: number, y: number, z: number): number {
      return y ^ (x | ~z)
    }

    function ff(
      a: number,
      b: number,
      c: number,
      d: number,
      x: number,
      s: number,
      ac: number,
    ): number {
      a = addUnsigned(a, addUnsigned(addUnsigned(f(b, c, d), x), ac))
      return addUnsigned(rotateLeft(a, s), b)
    }

    function gg(
      a: number,
      b: number,
      c: number,
      d: number,
      x: number,
      s: number,
      ac: number,
    ): number {
      a = addUnsigned(a, addUnsigned(addUnsigned(g(b, c, d), x), ac))
      return addUnsigned(rotateLeft(a, s), b)
    }

    function hh(
      a: number,
      b: number,
      c: number,
      d: number,
      x: number,
      s: number,
      ac: number,
    ): number {
      a = addUnsigned(a, addUnsigned(addUnsigned(h(b, c, d), x), ac))
      return addUnsigned(rotateLeft(a, s), b)
    }

    function ii(
      a: number,
      b: number,
      c: number,
      d: number,
      x: number,
      s: number,
      ac: number,
    ): number {
      a = addUnsigned(a, addUnsigned(addUnsigned(i(b, c, d), x), ac))
      return addUnsigned(rotateLeft(a, s), b)
    }

    function convertToWordArray(str: string): number[] {
      let wordCount: number
      const messageLength = str.length
      const temp1 = messageLength + 8
      const temp2 = (temp1 - (temp1 % 64)) / 64
      const numberOfWords = (temp2 + 1) * 16
      const wordArray: number[] = new Array(numberOfWords - 1)
      let bytePosition: number
      let byteCount = 0
      while (byteCount < messageLength) {
        wordCount = (byteCount - (byteCount % 4)) / 4
        bytePosition = (byteCount % 4) * 8
        wordArray[wordCount] =
          wordArray[wordCount] | (str.charCodeAt(byteCount) << bytePosition)
        byteCount++
      }
      wordCount = (byteCount - (byteCount % 4)) / 4
      bytePosition = (byteCount % 4) * 8
      wordArray[wordCount] = wordArray[wordCount] | (0x80 << bytePosition)
      wordArray[numberOfWords - 2] = messageLength << 3
      wordArray[numberOfWords - 1] = messageLength >>> 29
      return wordArray
    }

    function wordToHex(value: number): string {
      let hex = ''
      for (let i = 0; i <= 3; i++) {
        const byte = (value >>> (i * 8)) & 255
        hex += ('0' + byte.toString(16)).slice(-2)
      }
      return hex
    }

    const x = convertToWordArray(string)
    let a = 0x67452301,
      b = 0xefcdab89,
      c = 0x98badcfe,
      d = 0x10325476

    const S11 = 7,
      S12 = 12,
      S13 = 17,
      S14 = 22
    const S21 = 5,
      S22 = 9,
      S23 = 14,
      S24 = 20
    const S31 = 4,
      S32 = 11,
      S33 = 16,
      S34 = 23
    const S41 = 6,
      S42 = 10,
      S43 = 15,
      S44 = 21

    for (let k = 0; k < x.length; k += 16) {
      const AA = a,
        BB = b,
        CC = c,
        DD = d
      a = ff(a, b, c, d, x[k + 0], S11, 0xd76aa478)
      d = ff(d, a, b, c, x[k + 1], S12, 0xe8c7b756)
      c = ff(c, d, a, b, x[k + 2], S13, 0x242070db)
      b = ff(b, c, d, a, x[k + 3], S14, 0xc1bdceee)
      a = ff(a, b, c, d, x[k + 4], S11, 0xf57c0faf)
      d = ff(d, a, b, c, x[k + 5], S12, 0x4787c62a)
      c = ff(c, d, a, b, x[k + 6], S13, 0xa8304613)
      b = ff(b, c, d, a, x[k + 7], S14, 0xfd469501)
      a = ff(a, b, c, d, x[k + 8], S11, 0x698098d8)
      d = ff(d, a, b, c, x[k + 9], S12, 0x8b44f7af)
      c = ff(c, d, a, b, x[k + 10], S13, 0xffff5bb1)
      b = ff(b, c, d, a, x[k + 11], S14, 0x895cd7be)
      a = ff(a, b, c, d, x[k + 12], S11, 0x6b901122)
      d = ff(d, a, b, c, x[k + 13], S12, 0xfd987193)
      c = ff(c, d, a, b, x[k + 14], S13, 0xa679438e)
      b = ff(b, c, d, a, x[k + 15], S14, 0x49b40821)
      a = gg(a, b, c, d, x[k + 1], S21, 0xf61e2562)
      d = gg(d, a, b, c, x[k + 6], S22, 0xc040b340)
      c = gg(c, d, a, b, x[k + 11], S23, 0x265e5a51)
      b = gg(b, c, d, a, x[k + 0], S24, 0xe9b6c7aa)
      a = gg(a, b, c, d, x[k + 5], S21, 0xd62f105d)
      d = gg(d, a, b, c, x[k + 10], S22, 0x2441453)
      c = gg(c, d, a, b, x[k + 15], S23, 0xd8a1e681)
      b = gg(b, c, d, a, x[k + 4], S24, 0xe7d3fbc8)
      a = gg(a, b, c, d, x[k + 9], S21, 0x21e1cde6)
      d = gg(d, a, b, c, x[k + 14], S22, 0xc33707d6)
      c = gg(c, d, a, b, x[k + 3], S23, 0xf4d50d87)
      b = gg(b, c, d, a, x[k + 8], S24, 0x455a14ed)
      a = gg(a, b, c, d, x[k + 13], S21, 0xa9e3e905)
      d = gg(d, a, b, c, x[k + 2], S22, 0xfcefa3f8)
      c = gg(c, d, a, b, x[k + 7], S23, 0x676f02d9)
      b = gg(b, c, d, a, x[k + 12], S24, 0x8d2a4c8a)
      a = hh(a, b, c, d, x[k + 5], S31, 0xfffa3942)
      d = hh(d, a, b, c, x[k + 8], S32, 0x8771f681)
      c = hh(c, d, a, b, x[k + 11], S33, 0x6d9d6122)
      b = hh(b, c, d, a, x[k + 14], S34, 0xfde5380c)
      a = hh(a, b, c, d, x[k + 1], S31, 0xa4beea44)
      d = hh(d, a, b, c, x[k + 4], S32, 0x4bdecfa9)
      c = hh(c, d, a, b, x[k + 7], S33, 0xf6bb4b60)
      b = hh(b, c, d, a, x[k + 10], S34, 0xbebfbc70)
      a = hh(a, b, c, d, x[k + 13], S31, 0x289b7ec6)
      d = hh(d, a, b, c, x[k + 0], S32, 0xeaa127fa)
      c = hh(c, d, a, b, x[k + 3], S33, 0xd4ef3085)
      b = hh(b, c, d, a, x[k + 6], S34, 0x4881d05)
      a = hh(a, b, c, d, x[k + 9], S31, 0xd9d4d039)
      d = hh(d, a, b, c, x[k + 12], S32, 0xe6db99e5)
      c = hh(c, d, a, b, x[k + 15], S33, 0x1fa27cf8)
      b = hh(b, c, d, a, x[k + 2], S34, 0xc4ac5665)
      a = ii(a, b, c, d, x[k + 0], S41, 0xf4292244)
      d = ii(d, a, b, c, x[k + 7], S42, 0x432aff97)
      c = ii(c, d, a, b, x[k + 14], S43, 0xab9423a7)
      b = ii(b, c, d, a, x[k + 5], S44, 0xfc93a039)
      a = ii(a, b, c, d, x[k + 12], S41, 0x655b59c3)
      d = ii(d, a, b, c, x[k + 3], S42, 0x8f0ccc92)
      c = ii(c, d, a, b, x[k + 10], S43, 0xffeff47d)
      b = ii(b, c, d, a, x[k + 1], S44, 0x85845dd1)
      a = ii(a, b, c, d, x[k + 8], S41, 0x6fa87e4f)
      d = ii(d, a, b, c, x[k + 15], S42, 0xfe2ce6e0)
      c = ii(c, d, a, b, x[k + 6], S43, 0xa3014314)
      b = ii(b, c, d, a, x[k + 13], S44, 0x4e0811a1)
      a = ii(a, b, c, d, x[k + 4], S41, 0xf7537e82)
      d = ii(d, a, b, c, x[k + 11], S42, 0xbd3af235)
      c = ii(c, d, a, b, x[k + 2], S43, 0x2ad7d2bb)
      b = ii(b, c, d, a, x[k + 9], S44, 0xeb86d391)
      a = addUnsigned(a, AA)
      b = addUnsigned(b, BB)
      c = addUnsigned(c, CC)
      d = addUnsigned(d, DD)
    }

    return (
      wordToHex(a) +
      wordToHex(b) +
      wordToHex(c) +
      wordToHex(d)
    ).toLowerCase()
  }

  async function initComments() {
    const section = document.querySelector('.comments-section') as HTMLElement
    if (!section) {
      commentsWindow.__astroDogeCommentsController?.abort()
      commentsWindow.__astroDogeCommentsController = undefined
      return
    }

    if (section.dataset.commentsBound === 'true') return

    commentsWindow.__astroDogeCommentsController?.abort()
    const controller = new AbortController()
    const { signal } = controller
    commentsWindow.__astroDogeCommentsController = controller
    section.dataset.commentsBound = 'true'

    const slug = section.dataset.slug
    const title = section.dataset.title
    const ownerName = section.dataset.ownerName || ''
    const ownerEmail = section.dataset.ownerEmail || ''
    let avatarDebounceTimer: ReturnType<typeof setTimeout> | null = null

    signal.addEventListener(
      'abort',
      () => {
        if (avatarDebounceTimer) clearTimeout(avatarDebounceTimer)
      },
      { once: true },
    )

    const emojisConfig = await loadEmojisConfig()
    if (signal.aborted) return

    const form = document.getElementById('comment-form') as HTMLFormElement

    const contentTextarea = document.getElementById(
      'comment-content',
    ) as HTMLTextAreaElement
    const charCount = document.getElementById('char-count') as HTMLElement
    const nameInput = document.getElementById(
      'comment-name',
    ) as HTMLInputElement
    const emailInput = document.getElementById(
      'comment-email',
    ) as HTMLInputElement
    const websiteInput = document.getElementById(
      'comment-website',
    ) as HTMLInputElement
    const avatarPreview = document.getElementById(
      'avatar-preview',
    ) as HTMLImageElement

    const commentsLoading = document.getElementById(
      'comments-loading',
    ) as HTMLElement
    const commentsList = document.getElementById('comments-list') as HTMLElement
    const commentsEmpty = document.getElementById(
      'comments-empty',
    ) as HTMLElement
    const commentsError = document.getElementById(
      'comments-error',
    ) as HTMLElement
    const commentsCount = document.getElementById(
      'comments-count',
    ) as HTMLElement
    const countNumber = document.getElementById('count-number') as HTMLElement
    const retryBtn = document.getElementById('retry-load') as HTMLButtonElement
    let toastContainer = document.getElementById(
      'toast-container',
    ) as HTMLElement
    if (!toastContainer) {
      toastContainer = document.createElement('div')
      toastContainer.id = 'toast-container'
      toastContainer.className =
        'fixed bottom-10 left-1/2 z-50 flex -translate-x-1/2 flex-col gap-2 transition-all'
      document.body.appendChild(toastContainer)
    }

    // 表情选择器
    const emojiBtn = document.getElementById('emoji-btn') as HTMLButtonElement
    const emojiPicker = document.getElementById('emoji-picker') as HTMLElement
    const emojiTabs = document.getElementById('emoji-tabs') as HTMLElement
    const emojiContent = document.getElementById('emoji-content') as HTMLElement

    const packNames = Object.keys(emojisConfig)
    let currentEmojiTarget: HTMLTextAreaElement | null = null

    // 更新头像预览（带防抖）
    function updateAvatarPreview() {
      const email = emailInput.value.trim().toLowerCase()

      avatarPreview.style.opacity = '0.5'

      if (avatarDebounceTimer) {
        clearTimeout(avatarDebounceTimer)
      }

      avatarDebounceTimer = setTimeout(() => {
        if (email && email.includes('@')) {
          const hash = md5(email)
          avatarPreview.src = `https://weavatar.com/avatar/${hash}?d=identicon&s=80`
        } else {
          avatarPreview.src = 'https://weavatar.com/avatar/?d=mp&s=80'
        }
        avatarPreview.style.opacity = '1'
      }, GRAVATAR_DEBOUNCE)
    }

    emailInput?.addEventListener('input', updateAvatarPreview, { signal })

    // 初始化表情选择器
    function initEmojiPicker() {
      if (!emojiTabs || !emojiContent || packNames.length === 0) return

      emojiTabs.innerHTML = packNames
        .map((packKey, index) => {
          const pack = emojisConfig[packKey]
          return `
          <button type="button" data-pack="${packKey}" title="${pack.name}"
            class="rounded px-2 py-1 text-xs text-nowrap transition ${index === 0 ? 'bg-stone-100 text-stone-900 dark:bg-stone-700 dark:text-stone-100' : 'text-stone-500 hover:bg-stone-100 dark:text-stone-400 dark:hover:bg-stone-800'}">
            ${pack.name}
          </button>
        `
        })
        .join('')

      if (packNames.length > 0) {
        renderEmojiPack(packNames[0])
      }

      emojiTabs.addEventListener(
        'click',
        (e) => {
          const tab = (e.target as HTMLElement).closest(
            '[data-pack]',
          ) as HTMLElement
          if (tab) {
            const packKey = tab.dataset.pack || ''
            emojiTabs.querySelectorAll('button').forEach((t) => {
              const isActive = t.getAttribute('data-pack') === packKey
              t.className = `rounded px-2 py-1 text-xs text-nowrap transition ${isActive ? 'bg-stone-100 text-stone-900 dark:bg-stone-700 dark:text-stone-100' : 'text-stone-500 hover:bg-stone-100 dark:text-stone-400 dark:hover:bg-stone-800'}`
            })
            renderEmojiPack(packKey)
          }
        },
        { signal },
      )
    }

    function renderEmojiPack(packKey: string) {
      const pack = emojisConfig[packKey]
      if (!pack || !emojiContent) return

      const isImage = pack.type === 'image'
      const size = pack.size || 24

      const htmlPrefix = isImage
        ? `<div class="grid gap-1" style="grid-template-columns: repeat(${size >= 60 ? 4 : size >= 40 ? 6 : 8}, minmax(0, 1fr));">`
        : `<div class="flex flex-wrap gap-1">`

      let html =
        htmlPrefix +
        Object.entries(pack.items)
          .map(([name, value]) => {
            const emojiCode = `:${packKey}_${name}:`
            if (isImage) {
              return `
            <button type="button" data-emoji="${emojiCode}" title="${name}"
              class="flex items-center justify-center rounded p-1 transition-all hover:bg-stone-100 active:scale-95 dark:hover:bg-stone-700">
              <img alt="${name}" loading="lazy"
                class="object-contain"
                src="${value}" style="width:${size}px;height:${size}px;" />
            </button>
          `
            } else {
              // 颜文字样式优化
              return `
            <button type="button" data-emoji="${value}" title="${name}"
              class="rounded px-2 py-1 text-sm transition-colors hover:bg-stone-100 dark:hover:bg-stone-700">
              ${value}
            </button>
          `
            }
          })
          .join('')

      html += `</div>`
      emojiContent.innerHTML = html
    }

    emojiContent?.addEventListener(
      'click',
      (e) => {
        const item = (e.target as HTMLElement).closest(
          '[data-emoji]',
        ) as HTMLElement
        const target = currentEmojiTarget || contentTextarea

        if (item && target) {
          const emoji = item.dataset.emoji || ''
          const start = target.selectionStart
          const end = target.selectionEnd
          const text = target.value
          target.value = text.substring(0, start) + emoji + text.substring(end)
          target.selectionStart = target.selectionEnd = start + emoji.length
          target.focus()

          // 如果是主评论框，更新字数统计
          if (target === contentTextarea) {
            charCount.textContent = String(target.value.length)
          }

          emojiPicker?.classList.add('hidden')
        }
      },
      { signal },
    )

    emojiBtn?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        currentEmojiTarget = contentTextarea

        const container = emojiBtn.parentElement
        if (container) {
          if (!container.contains(emojiPicker)) {
            container.appendChild(emojiPicker)
            emojiPicker?.classList.remove('hidden')
          } else {
            emojiPicker?.classList.toggle('hidden')
          }
        }
      },
      { signal },
    )

    document.addEventListener(
      'click',
      (e) => {
        if (
          emojiPicker &&
          !emojiPicker.contains(e.target as Node) &&
          e.target !== emojiBtn &&
          !emojiBtn?.contains(e.target as Node)
        ) {
          emojiPicker.classList.add('hidden')
        }
      },
      { signal },
    )

    initEmojiPicker()

    function loadSavedUserInfo() {
      try {
        const saved = localStorage.getItem(STORAGE_KEY)
        if (saved) {
          const info: StoredUserInfo = JSON.parse(saved)
          if (info.name) nameInput.value = info.name
          if (info.email) {
            emailInput.value = info.email
            const hash = md5(info.email.toLowerCase().trim())
            avatarPreview.src = `https://weavatar.com/avatar/${hash}?d=identicon&s=80`
          }
          if (info.website) websiteInput.value = info.website
        }
      } catch {
        // 忽略解析错误
      }
    }

    loadSavedUserInfo()

    contentTextarea?.addEventListener(
      'input',
      () => {
        const count = contentTextarea.value.length
        charCount.textContent = String(count)
      },
      { signal },
    )

    function escapeHtml(text: string) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;')
    }

    function getSuccessMessage(isReply: boolean) {
      if (slug === 'messages') {
        return isReply
          ? '收到啦，已经接上这段聊天。同步需要半分钟。'
          : '收到啦，欢迎来这里串门。同步需要半分钟。'
      }

      return isReply
        ? '回复已收到，正在同步到评论区。'
        : '评论已收到，正在同步到评论区。'
    }

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      const toast = document.createElement('div')
      toast.className = `transform transition-all duration-300 ease-out translate-y-full opacity-0 flex items-center gap-2 rounded-lg border border-stone-200 bg-white px-4 py-3 text-sm font-medium text-stone-900 shadow-xl dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100`
      const safeMessage = escapeHtml(message)

      toast.innerHTML = `
        ${
          type === 'success'
            ? '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>'
            : '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>'
        }
        <span>${safeMessage}</span>
      `
      toastContainer.appendChild(toast)

      // Animate in
      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-full', 'opacity-0')
      })

      // Remove after delay
      setTimeout(() => {
        toast.classList.add('translate-y-full', 'opacity-0')
        setTimeout(() => {
          toast.remove()
        }, 300)
      }, 3000)
    }

    // 获取用户信息（优先从 localStorage，其次从主表单）
    function getSavedUserInfo(): StoredUserInfo {
      try {
        const saved = localStorage.getItem(STORAGE_KEY)
        if (saved) {
          const info = JSON.parse(saved) as StoredUserInfo
          return {
            name: info.name || nameInput?.value || '',
            email: info.email || emailInput?.value || '',
            website: info.website || websiteInput?.value || '',
          }
        }
      } catch {
        // 忽略
      }
      return {
        name: nameInput?.value || '',
        email: emailInput?.value || '',
        website: websiteInput?.value || '',
      }
    }


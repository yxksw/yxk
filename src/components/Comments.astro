    function bindRenderedCommentActions() {
      // 绑定回复按钮事件
      commentsList.querySelectorAll('.reply-btn').forEach((btn) => {
        btn.addEventListener(
          'click',
          (e) => {
            const button = (e.target as HTMLElement).closest(
              '.reply-btn',
            ) as HTMLButtonElement
            const article = button.closest('article')
            if (article) {
              handleReplyClick(article as HTMLElement, button)
            }
          },
          { signal },
        )
      })

      // 绑定展开/收起回复事件
      commentsList.querySelectorAll('.toggle-replies-btn').forEach((btn) => {
        btn.addEventListener(
          'click',
          (e) => {
            const button = (e.target as HTMLElement).closest(
              '.toggle-replies-btn',
            ) as HTMLButtonElement
            if (!button) return

            const targetId = button.dataset.target
            const isExpanded = button.dataset.expanded === 'true'
            const container = commentsList.querySelector(
              `.replies-container[data-parent-id="${targetId}"]`,
            )

            if (container) {
              if (isExpanded) {
                container.classList.add('hidden')
                button.dataset.expanded = 'false'
                const textEl = button.querySelector('.toggle-text')
                const iconEl = button.querySelector('.toggle-icon')
                if (textEl) {
                  const count = container.querySelectorAll(
                    '.comment-reply-item',
                  ).length
                  textEl.textContent = `展开回复 (${count})`
                }
                if (iconEl) iconEl.classList.remove('rotate-180')
              } else {
                container.classList.remove('hidden')
                button.dataset.expanded = 'true'
                const textEl = button.querySelector('.toggle-text')
                const iconEl = button.querySelector('.toggle-icon')
                if (textEl) {
                  const count = container.querySelectorAll(
                    '.comment-reply-item',
                  ).length
                  textEl.textContent = `收起回复 (${count})`
                }
                if (iconEl) iconEl.classList.add('rotate-180')
              }
            }
          },
          { signal },
        )
      })
    }

    function displayComments(comments: Comment[]) {
      commentsLoading.classList.add('hidden')

      if (comments.length === 0) {
        commentsEmpty.classList.remove('hidden')
        return
      }

      // 只统计顶层评论数量
      const totalCount = comments.length

      commentsList.innerHTML = comments
        .map((c) => renderComment(c, false))
        .join('')
      commentsList.classList.remove('hidden')
      countNumber.textContent = String(totalCount)
      commentsCount.classList.remove('hidden')
      bindRenderedCommentActions()
    }

    // 加载评论
    async function loadComments() {
      try {
        commentsLoading.classList.remove('hidden')
        commentsList.classList.add('hidden')
        commentsEmpty.classList.add('hidden')
        commentsError.classList.add('hidden')
        commentsCount.classList.add('hidden')

        const response = await fetch(
          `/api/comments?slug=${encodeURIComponent(slug!)}`,
          { signal },
        )

        if (signal.aborted) return

        if (!response.ok) {
          throw new Error('Failed to fetch comments')
        }

        const contentType = response.headers.get('content-type') || ''
        if (!contentType.includes('application/json')) {
          throw new Error('Comments API did not return JSON')
        }

        const data = await response.json()
        let comments: Comment[] = data.comments || []
        if (signal.aborted) return

        // 合并本地待确认评论
        comments = mergeWithPendingComments(comments, slug!)

        // 按最新发布在前排序（降序）
        comments = comments.slice().sort((a, b) => {
          return (
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
          )
        })

        displayComments(comments)
      } catch (error) {
        if (signal.aborted) return

        if (isLocalDevHost()) {
          console.warn('Comments API is unavailable in local dev:', error)
          const mockComments = mergeWithPendingComments(
            getMockComments(slug || 'messages'),
            slug!,
          )
          displayComments(mockComments)
        } else {
          console.error('Load comments error:', error)
          commentsLoading.classList.add('hidden')
          commentsError.classList.remove('hidden')
        }
      }
    }

    retryBtn?.addEventListener('click', loadComments, { signal })

    // 处理回复按钮点击（提取为函数以便复用）
    function handleReplyClick(
      article: HTMLElement,
      button?: HTMLButtonElement,
    ) {
      // 检查是否是临时评论或待同步评论，如果是则不允许回复
      if (
        (article as HTMLElement).dataset.temp === 'true' ||
        (article as HTMLElement).dataset.pending === 'true'
      ) {
        showToast('评论正在同步中，请稍候...', 'success')
        return
      }

      const replyBtn = button || article.querySelector('.reply-btn')
      const container = article.querySelector('.reply-form-container')
      if (!container || !replyBtn) return

      // 如果已经打开，则关闭
      if (container.innerHTML !== '') {
        container.innerHTML = ''
        replyBtn.innerHTML = `回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>`
        return
      }

      // 关闭其他打开的回复框
      document
        .querySelectorAll('.reply-form-container')
        .forEach((el) => (el.innerHTML = ''))
      document
        .querySelectorAll('.reply-btn')
        .forEach(
          (el) =>
            (el.innerHTML = `回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>`),
        )

      const id = parseInt(article.dataset.id || '0')
      const name = article.dataset.name || ''
      container.innerHTML = createReplyFormHtml(id, name)
      replyBtn.innerHTML = `取消回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`

      // 绑定新表单的事件
      const form = container.querySelector('form')
      const cancelBtn = container.querySelector('.cancel-reply-btn')
      const emojiBtnReply = container.querySelector('.reply-emoji-btn')
      const textarea = container.querySelector('textarea')

      if (form) {
        form.addEventListener('submit', (ev) => submitComment(ev, form), {
          signal,
        })
      }

      if (cancelBtn) {
        cancelBtn.addEventListener(
          'click',
          () => {
            container.innerHTML = ''
            replyBtn.innerHTML = `回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>`
          },
          { signal },
        )
      }

      if (emojiBtnReply && textarea) {
        emojiBtnReply.addEventListener(
          'click',
          (ev) => {
            ev.stopPropagation()
            currentEmojiTarget = textarea as HTMLTextAreaElement

            const emojiContainer = emojiBtnReply.parentElement
            if (emojiContainer) {
              if (!emojiContainer.contains(emojiPicker)) {
                emojiContainer.appendChild(emojiPicker)
                emojiPicker.classList.remove('hidden')
              } else {
                emojiPicker.classList.toggle('hidden')
              }
            }
          },
          { signal },
        )
      }
    }


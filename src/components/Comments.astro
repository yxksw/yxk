    async function submitComment(e: Event, targetForm: HTMLFormElement) {
      e.preventDefault()

      const formData = new FormData(targetForm)
      const name = formData.get('name') as string
      const email = (formData.get('email') as string) || undefined

      const isOwnerName = ownerName !== '' && name === ownerName
      const isOwnerEmail = ownerEmail !== '' && email === ownerEmail

      // 检查是否需要博主验证（名称或邮箱任一匹配都需要验证）
      let ownerToken: string | undefined = undefined
      let isVerifiedOwner = false

      if (isOwnerName || isOwnerEmail) {
        const storedToken = localStorage.getItem('owner_token')
        if (!storedToken) {
          const token = prompt('名称或邮箱与博主相同，请输入验证 token：')
          if (!token) {
            showToast('需要验证博主身份', 'error')
            return
          }
          ownerToken = token
        } else {
          ownerToken = storedToken
        }
        // 只有名称和邮箱都匹配才是真正的博主
        isVerifiedOwner = isOwnerName && isOwnerEmail
      }

      const replyToIdRaw = (formData.get('replyToId') as string) || undefined

      // 检查 replyToId 是否为临时 id（时间戳格式，大于 1600000000000）
      // GitHub comment id 通常是较小的数字，而临时 id 是 Date.now() 返回的毫秒时间戳
      if (replyToIdRaw) {
        const replyToIdNum = parseInt(replyToIdRaw)
        if (replyToIdNum > 1600000000000) {
          showToast('该评论正在同步中，请刷新页面后再回复', 'error')
          return
        }
      }

      const payload: CommentPayload = {
        slug,
        title,
        name,
        email,
        website: (formData.get('website') as string) || undefined,
        content: formData.get('content') as string,
        replyToId: replyToIdRaw,
        replyToName: (formData.get('replyToName') as string) || undefined,
        _gotcha: formData.get('_gotcha') as string,
        userAgent: navigator.userAgent,
      }

      if (ownerToken) {
        payload.ownerToken = ownerToken
      }

      const isMainForm = targetForm.id === 'comment-form'
      const submitBtnCurrent = targetForm.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement
      const submitTextCurrent = submitBtnCurrent.querySelector('span')
      const submitSpinnerCurrent =
        submitBtnCurrent.querySelector('.animate-spin')
      const submitIconCurrent = submitBtnCurrent.querySelector(
        'svg:not(.animate-spin)',
      )
      const nameInputCurrent = targetForm.querySelector(
        'input[name="name"]',
      ) as HTMLInputElement
      const contentInputCurrent = targetForm.querySelector(
        'textarea',
      ) as HTMLTextAreaElement

      if (!payload.name?.trim()) {
        showToast('请留下称呼', 'error')
        nameInputCurrent?.focus()
        return
      }

      if (!payload.content?.trim()) {
        showToast('内容不能为空', 'error')
        contentInputCurrent?.focus()
        return
      }

      // 先保存用户信息到 localStorage（在 reset 表单之前）
      const userInfoToSave: StoredUserInfo = {
        name: payload.name,
        email: payload.email || '',
        website: payload.website,
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(userInfoToSave))

      // 如果是回复表单，同步更新主表单的值
      if (!isMainForm) {
        if (nameInput) nameInput.value = userInfoToSave.name
        if (emailInput) emailInput.value = userInfoToSave.email
        if (websiteInput && userInfoToSave.website)
          websiteInput.value = userInfoToSave.website
      }

      submitBtnCurrent.disabled = true
      if (submitTextCurrent) submitTextCurrent.textContent = '发送中...'
      submitIconCurrent?.classList.add('hidden')
      submitSpinnerCurrent?.classList.remove('hidden')

      try {
        const response = await fetch('/api/submit-comment', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        })

        const data = await response.json()

        if (!response.ok) {
          // 如果是博主 token 验证失败，清除缓存的 token
          if (response.status === 403 && ownerToken) {
            localStorage.removeItem('owner_token')
          }
          throw new Error(data.error || '提交失败')
        }

        // 如果是博主评论且验证成功，缓存 token
        if (ownerToken) {
          localStorage.setItem('owner_token', ownerToken)
        }

        if (data.command) {
          showToast(data.message || '管理操作已完成')

          const contentInput = targetForm.querySelector(
            'textarea',
          ) as HTMLTextAreaElement
          if (contentInput) contentInput.value = ''

          if (isMainForm) {
            charCount.textContent = '0'
          } else {
            targetForm.parentElement!.innerHTML = ''
            const article = commentsList.querySelector(
              `article[data-id="${payload.replyToId}"]`,
            )
            const replyBtn = article?.querySelector('.reply-btn')
            if (replyBtn) {
              replyBtn.innerHTML = `回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>`
            }
          }

          await loadComments()
          return
        }

        showToast(getSuccessMessage(!isMainForm))

        // 只重置内容，保留用户信息
        const contentInput = targetForm.querySelector(
          'textarea',
        ) as HTMLTextAreaElement
        if (contentInput) contentInput.value = ''

        if (isMainForm) {
          charCount.textContent = '0'
          // 恢复用户信息到表单（因为我们不再调用 reset）
          const savedInfo = getSavedUserInfo()
          if (nameInput) nameInput.value = savedInfo.name
          if (emailInput) emailInput.value = savedInfo.email
          if (websiteInput) websiteInput.value = savedInfo.website || ''
        } else {
          // 如果是回复，关闭回复框
          targetForm.parentElement!.innerHTML = ''
          // 恢复回复按钮状态
          const article = commentsList.querySelector(
            `article[data-id="${payload.replyToId}"]`,
          )
          if (article) {
            const replyBtn = article.querySelector('.reply-btn')
            if (replyBtn) {
              replyBtn.innerHTML = `回复 <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>`
            }
          }
        }

        // 保存到本地缓存并立即显示（不再轮询，刷新页面时会自动验证）
        saveAndDisplayComment(payload, !isMainForm, isVerifiedOwner)
      } catch (error) {
        console.error('Submit error:', error)
        showToast('提交失败，请重试', 'error')
      } finally {
        submitBtnCurrent.disabled = false
        if (submitTextCurrent)
          submitTextCurrent.textContent = isMainForm ? '提交留言' : '提交回复'
        submitIconCurrent?.classList.remove('hidden')
        submitSpinnerCurrent?.classList.add('hidden')
      }
    }

    form?.addEventListener('submit', (e) => submitComment(e, form), {
      signal,
    })

    loadComments()
  }

  document.addEventListener('DOMContentLoaded', initComments)
  document.addEventListener('astro:after-swap', initComments)

  if (document.readyState === 'complete') {
    initComments()
  }
</script>


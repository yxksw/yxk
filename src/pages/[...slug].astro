---
import { type CollectionEntry, getCollection, render } from 'astro:content'
import Comments from '@components/Comments.astro'
import Container from '@components/Container.astro'
import FormattedDate from '@components/FormattedDate.astro'
import TableOfContents from '@components/TableOfContents.astro'
import PageLayout from '@layouts/PageLayout.astro'
import { isVisiblePost, showDraftPosts } from '@lib/posts'
import { readingTime, wordCount } from '@lib/utils'

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts'))
    .filter((post: CollectionEntry<'posts'>) => isVisiblePost(post))
    .sort(
      (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
        b.data.date.valueOf() - a.data.date.valueOf(),
    )
  return allPosts.map((post: CollectionEntry<'posts'>) => ({
    params: { slug: post.data.slug || post.id },
    props: post,
  }))
}

type Props = CollectionEntry<'posts'>

const post = Astro.props
const { Content } = await render(post)
const postPath = post.data.slug || post.id
const postBody = post.body ?? ''
const tags = post.data.tags ?? []
const postReactions = [
  { id: 'like', icon: '♡', activeIcon: '♥', label: '喜欢', effect: 'like' },
  { id: 'star', icon: '☆', activeIcon: '★', label: '记住', effect: 'star' },
  {
    id: 'firework',
    icon: '✺',
    activeIcon: '✹',
    label: '烟花',
    effect: 'firework',
  },
]
---

<PageLayout
  title={post.data.title}
  description={post.data.description || post.data.title}
  image={post.data.cover}
>
  <Container class="!max-w-none">
    <div class="relative">
      <div class="mx-auto max-w-[680px] min-w-0">
        {
          post.data.cover && (
            <div class="post-cover cover-frame mb-8">
              <img
                src={post.data.cover}
                alt={post.data.title}
                class="cover-image h-auto"
                loading="eager"
                decoding="async"
              />
            </div>
          )
        }

        <header class="mb-10">
          <h1
            class="max-w-3xl text-3xl leading-tight font-semibold text-stone-950 sm:text-4xl dark:text-stone-50"
          >
            {post.data.title}
            {
              showDraftPosts && post.data.draft && (
                <span class="ml-3 inline-flex rounded-md border border-rose-200 bg-rose-50 px-2 py-1 align-middle text-xs font-medium text-rose-500 dark:border-rose-900/60 dark:bg-rose-950/30 dark:text-rose-300">
                  草稿
                </span>
              )
            }
          </h1>
          <div
            class="mt-5 flex flex-wrap items-center gap-2 text-sm text-stone-500 dark:text-stone-400"
          >
            <span class="inline-flex items-center gap-1.5 font-mono">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"
                ></path></svg
              >
              <FormattedDate date={post.data.date} />
            </span>
            <span class="text-stone-300 dark:text-stone-700">·</span>
            <span>{readingTime(postBody)}</span>
            <span class="text-stone-300 dark:text-stone-700">·</span>
            <span>{wordCount(postBody).toLocaleString()} 字</span>
            {tags.map((tag) => <span class="chip ml-1">{tag}</span>)}
          </div>
        </header>

        <article class="post-content">
          <Content />
        </article>

        <div class="my-12 flex items-center gap-4">
          <div
            class="h-px flex-1 bg-gradient-to-r from-transparent to-[var(--line-strong)]"
          >
          </div>
          <span class="shrink-0 text-sm text-stone-400 dark:text-stone-500">
            End
          </span>
          <div
            class="h-px flex-1 bg-gradient-to-l from-transparent to-[var(--line-strong)]"
          >
          </div>
        </div>

        <section
          class="post-reactions"
          data-post-reactions
          data-post-key={postPath}
          aria-label="读完反应"
        >
          <p class="post-reactions-label">读完了，轻轻留个反应</p>
          <div class="post-reactions-actions">
            {
              postReactions.map((reaction) => (
                <button
                  type="button"
                  class="post-reaction-button"
                  data-reaction={reaction.id}
                  data-effect={reaction.effect}
                  aria-label={reaction.label}
                  aria-pressed="false"
                  title={reaction.label}
                >
                  <span
                    class="post-reaction-icon post-reaction-icon--idle"
                    aria-hidden="true"
                  >
                    {reaction.icon}
                  </span>
                  <span
                    class="post-reaction-icon post-reaction-icon--active"
                    aria-hidden="true"
                  >
                    {reaction.activeIcon}
                  </span>
                </button>
              ))
            }
          </div>
        </section>

        <section class="mt-2 border-t border-[var(--line)] pt-10 sm:mt-4">
          <h2
            class="mb-6 text-base font-semibold text-stone-900 dark:text-stone-100"
          >
            评论
          </h2>
          <Comments slug={postPath} title={post.data.title} />
        </section>
      </div>

      <aside
        class="xl:fixed xl:top-24 xl:right-[max(1rem,calc((100vw-680px)/2-340px))] xl:z-30 xl:w-64"
      >
        <div class="pointer-events-auto">
          <TableOfContents />
        </div>
      </aside>
    </div>
  </Container>
</PageLayout>

<script>
  function showCopyToast(message: string) {
    let toast = document.getElementById('copy-toast')
    if (!toast) {
      toast = document.createElement('div')
      toast.id = 'copy-toast'
      toast.className =
        'fixed bottom-24 left-1/2 z-50 -translate-x-1/2 rounded-lg bg-stone-900/90 px-4 py-2 text-sm text-white opacity-0 shadow-lg transition-opacity duration-300 pointer-events-none dark:bg-stone-100 dark:text-stone-900 sm:bottom-8'
      document.body.appendChild(toast)
    }

    toast.textContent = `✓ ${message}`
    toast.classList.remove('opacity-0')
    toast.classList.add('opacity-100')
    setTimeout(() => {
      toast?.classList.remove('opacity-100')
      toast?.classList.add('opacity-0')
    }, 1800)
  }

  function setupArticleActions() {
    document
      .querySelectorAll('article.post-content .heading-anchor')
      .forEach((anchor) => {
        const el = anchor as HTMLAnchorElement
        if (el.dataset.anchorBound === 'true') return
        el.dataset.anchorBound = 'true'
        el.addEventListener('click', async (event) => {
          event.preventDefault()
          const href = el.getAttribute('href')
          if (!href) return
          const url = `${window.location.origin}${window.location.pathname}${href}`
          try {
            await navigator.clipboard.writeText(url)
            history.pushState(null, '', href)
            showCopyToast('标题链接已复制')
          } catch {
            showCopyToast('复制失败')
          }
        })
      })
  }

  function setupPostReactions() {
    document.querySelectorAll('[data-post-reactions]').forEach((root) => {
      const el = root as HTMLElement
      if (el.dataset.reactionsBound === 'true') return
      el.dataset.reactionsBound = 'true'

      const postKey = el.dataset.postKey || window.location.pathname
      const storageKey = `post-reactions:${postKey}`
      const buttons = Array.from(
        el.querySelectorAll<HTMLButtonElement>('[data-reaction]'),
      )

      const readSaved = (): Set<string> => {
        try {
          const value = window.localStorage.getItem(storageKey)
          const parsed = value ? JSON.parse(value) : []
          return Array.isArray(parsed)
            ? new Set<string>(
                parsed.filter(
                  (item): item is string => typeof item === 'string',
                ),
              )
            : new Set<string>()
        } catch {
          return new Set<string>()
        }
      }

      const writeSaved = (saved: Set<string>) => {
        window.localStorage.setItem(storageKey, JSON.stringify([...saved]))
      }

      const syncButtons = (saved: Set<string>) => {
        buttons.forEach((button) => {
          const active = saved.has(button.dataset.reaction || '')
          button.dataset.active = active ? 'true' : 'false'
          button.setAttribute('aria-pressed', String(active))
        })
      }

      const burst = (button: HTMLButtonElement) => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return
        }

        const rect = button.getBoundingClientRect()
        const effect = button.dataset.effect || 'star'
        const configs = {
          like: {
            symbols: ['♡', '♥', '♡', '·'],
            count: 8,
            className: 'reaction-particle--like',
          },
          star: {
            symbols: ['☆', '✦', '✧', '·'],
            count: 9,
            className: 'reaction-particle--star',
          },
          firework: {
            symbols: ['✺', '✹', '✷', '✦', '·'],
            count: 14,
            className: 'reaction-particle--firework',
          },
        } as const
        const config = configs[effect as keyof typeof configs] ?? configs.star

        for (let i = 0; i < config.count; i += 1) {
          const particle = document.createElement('span')
          particle.className = `reaction-particle ${config.className}`
          particle.textContent = config.symbols[i % config.symbols.length]
          particle.style.left = `${rect.left + rect.width / 2}px`
          particle.style.top = `${rect.top + rect.height / 2}px`
          const angle = (Math.PI * 2 * i) / config.count
          const spread = 36 + Math.random() * 42
          const x =
            effect === 'firework'
              ? Math.cos(angle) * spread
              : (Math.random() - 0.5) * (effect === 'like' ? 54 : 86)
          const y =
            effect === 'firework'
              ? Math.sin(angle) * spread
              : -30 - Math.random() * (effect === 'like' ? 38 : 54)
          particle.style.setProperty('--x', `${x}px`)
          particle.style.setProperty('--y', `${y}px`)
          particle.style.setProperty(
            '--rotate',
            `${Math.random() * 160 - 80}deg`,
          )
          particle.style.setProperty('--delay', `${i * 18}ms`)
          document.body.appendChild(particle)
          particle.addEventListener('animationend', () => particle.remove(), {
            once: true,
          })
        }
      }

      const saved = readSaved()
      syncButtons(saved)

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const reaction = button.dataset.reaction
          if (!reaction) return
          if (saved.has(reaction)) saved.delete(reaction)
          else saved.add(reaction)
          writeSaved(saved)
          syncButtons(saved)
          burst(button)
        })
      })
    })
  }

  document.addEventListener('DOMContentLoaded', setupArticleActions)
  document.addEventListener('astro:after-swap', setupArticleActions)
  document.addEventListener('DOMContentLoaded', setupPostReactions)
  document.addEventListener('astro:after-swap', setupPostReactions)
  if (document.readyState === 'complete') {
    setupArticleActions()
    setupPostReactions()
  }
</script>

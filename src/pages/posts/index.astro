---
import { type CollectionEntry, getCollection } from 'astro:content'
import Container from '@components/Container.astro'
import { BLOG } from '@consts'
import PageLayout from '@layouts/PageLayout.astro'
import { isVisiblePost, showDraftPosts } from '@lib/posts'
import { formatMD, readingTime } from '@lib/utils'

const data = (await getCollection('posts'))
  .filter((post) => isVisiblePost(post))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

type Acc = {
  [year: string]: CollectionEntry<'posts'>[]
}

const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString()
  if (!acc[year]) {
    acc[year] = []
  }
  acc[year].push(post)
  return acc
}, {})

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a))
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container class="!max-w-3xl">
    <div class="space-y-10">
      <section class="py-4">
        <h1
          class="text-3xl font-semibold text-stone-950 sm:text-4xl dark:text-stone-50"
        >
          文章
        </h1>
        <p
          class="mt-3 max-w-2xl leading-relaxed text-stone-600 dark:text-stone-400"
        >
          {`共 ${data.length} 篇文章，按年份分组展示。`}
        </p>
      </section>
      <div class="space-y-10">
        {
          years.map((year) => {
            return (
              <section class="grid gap-3 sm:grid-cols-[72px_minmax(0,1fr)] sm:gap-6">
                <div class="flex items-baseline gap-2 sm:block sm:pt-4">
                  <h2 class="font-mono text-xl font-semibold tracking-normal text-stone-900 sm:text-2xl dark:text-stone-100">
                    {year}
                  </h2>
                  <p class="font-mono text-xs text-stone-400 tabular-nums sm:mt-1 dark:text-stone-500">
                    {posts[year].length} 篇
                  </p>
                </div>
                <ul class="divide-y divide-stone-200/55 dark:divide-stone-800/70">
                  {posts[year].map((post) => (
                    <li class="min-w-0">
                      <a
                        href={`/${post.data.slug || post.id}`}
                        class="group block py-4.5"
                      >
                        <div class="flex min-w-0 flex-col gap-2.5 sm:flex-row sm:items-start sm:justify-between sm:gap-5">
                          <div class="min-w-0">
                            <h3 class="line-clamp-2 text-[17px] leading-snug font-semibold text-stone-800 transition-colors group-hover:text-stone-950 sm:text-lg dark:text-stone-200 dark:group-hover:text-stone-50">
                              {post.data.title}
                              <span
                                class="ml-1.5 inline-flex translate-x-[-3px] align-[-2px] text-stone-400 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 motion-safe:transition-[opacity,translate] motion-safe:duration-200 motion-safe:ease-out dark:text-stone-500"
                                aria-hidden="true"
                              >
                                <svg
                                  class="h-3.5 w-3.5"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                >
                                  <path d="M5 12h14" />
                                  <path d="m13 6 6 6-6 6" />
                                </svg>
                              </span>
                              {showDraftPosts && post.data.draft && (
                                <span class="ml-2 inline-flex rounded border border-rose-200 bg-rose-50 px-1.5 py-0.5 align-middle text-[10px] font-medium text-rose-500 dark:border-rose-900/60 dark:bg-rose-950/30 dark:text-rose-300">
                                  草稿
                                </span>
                              )}
                            </h3>
                            {post.data.description && (
                              <p class="mt-1.5 line-clamp-2 text-[14px] leading-6 text-stone-500 dark:text-stone-400">
                                {post.data.description}
                              </p>
                            )}
                          </div>
                          <div class="flex shrink-0 items-center gap-2 font-mono text-[11px] leading-5 text-stone-400 tabular-nums sm:pt-1.5 dark:text-stone-500">
                            <time datetime={post.data.date.toISOString()}>
                              {formatMD(post.data.date)}
                            </time>
                            <span class="text-stone-300 dark:text-stone-700">
                              ·
                            </span>
                            <span>{readingTime(post.body ?? '')}</span>
                          </div>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )
          })
        }
      </div>
    </div>
  </Container>
</PageLayout>

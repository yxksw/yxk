---
import { type CollectionEntry, getCollection } from 'astro:content'
import Container from '@components/Container.astro'
import Link from '@components/Link.astro'
import TechBadge from '@components/TechBadge.astro'
import { HOME, SITE } from '@consts'
import PageLayout from '@layouts/PageLayout.astro'
import { isVisiblePost, showDraftPosts } from '@lib/posts'
import { formatDate, readingTime, timeAgo } from '@lib/utils'

function extractPlainText(body: string): string {
  return body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/```(\w+)?[\s\S]*?```/g, (_, lang) =>
      lang ? `[代码: ${lang}]` : '[代码]',
    )
    .replace(/`[^`\n]+`/g, '[代码]')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/\*{1,3}([^*\n]+)\*{1,3}/g, '$1')
    .replace(/_{1,3}([^_\n]+)_{1,3}/g, '$1')
    .replace(/^>\s*/gm, '')
    .replace(/<[^>]+>/g, '')
    .replace(/\n+/g, ' ')
    .replace(/\s{2,}/g, ' ')
    .trim()
}

const posts = (await getCollection('posts'))
  .filter((post: CollectionEntry<'posts'>) => isVisiblePost(post))
  .sort(
    (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  )

const thoughts = (await getCollection('thoughts'))
  .filter((thought: CollectionEntry<'thoughts'>) => !thought.data.draft)
  .sort(
    (a: CollectionEntry<'thoughts'>, b: CollectionEntry<'thoughts'>) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  )

const accentClasses = [
  'bg-amber-300',
  'bg-rose-300',
  'bg-sky-300',
  'bg-emerald-300',
  'bg-indigo-300',
]

const featureItems = ['文章归档', '碎碎念', '相册', '评论 / 留言板', 'PWA']
const featureImagePost = posts.find((post) => post.data.cover)
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container class="!max-w-5xl">
    <div class="space-y-6">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_260px]">
        <section
          class="ink-shell ink-shell--flat relative overflow-hidden px-5 py-7 sm:px-8 sm:py-8"
        >
          <div
            class="grid items-center gap-6 md:grid-cols-[minmax(0,1fr)_150px]"
          >
            <div class="text-center sm:text-left">
              <div class="relative inline-block">
                <h1
                  class="text-4xl leading-none font-semibold tracking-normal text-stone-900 sm:text-5xl dark:text-stone-100"
                >
                  {SITE.NAME}
                </h1>
              </div>
              <p class="mt-4 text-sm text-stone-500 dark:text-stone-500">
                {SITE.DESCRIPTION}
              </p>
              <div
                class="mt-6 flex flex-wrap justify-center gap-2 sm:justify-start"
              >
                <TechBadge icon="bun.svg" name="Bun">Bun</TechBadge>
                <TechBadge icon="typescript.svg" name="TypeScript"
                  >TypeScript</TechBadge
                >
                <TechBadge icon="godot.svg" name="Astro Doge"
                  >Template</TechBadge
                >
              </div>
            </div>

            <div class="mx-auto hidden w-36 md:block">
              <picture>
                <source srcset="/hero.webp" type="image/webp" />
                <img
                  src="/hero.png"
                  alt="小狗插画"
                  width="420"
                  height="310"
                  class="h-auto w-full border-0 object-contain shadow-none"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </picture>
            </div>
          </div>
        </section>

        {
          featureImagePost?.data.cover && (
            <a
              href={`/${featureImagePost.data.slug || featureImagePost.id}`}
              class="cover-link cover-frame group relative hidden p-0 lg:block lg:min-h-full"
              aria-label={`阅读文章：${featureImagePost.data.title}`}
            >
              <img
                src={featureImagePost.data.cover}
                alt=""
                class="cover-image absolute inset-0 h-full"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/55 via-black/25 to-transparent p-4 text-white">
                <p class="text-xs opacity-80">最新文章</p>
                <p class="mt-1 line-clamp-2 text-sm leading-snug font-medium">
                  {featureImagePost.data.title}
                </p>
              </div>
            </a>
          )
        }
      </div>

      <div class="grid items-start gap-6 lg:grid-cols-[1.35fr_0.95fr]">
        <div class="flex flex-col gap-6">
          <section class="ink-card home-panel p-5 sm:p-6">
            <div class="mb-5 flex items-center justify-between gap-3">
              <h2
                class="text-lg font-semibold text-stone-900 dark:text-stone-100"
              >
                最近文章
              </h2>
              <Link
                href="/posts"
                underline={false}
                class="text-sm text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
              >
                查看全部文章 →
              </Link>
            </div>

            <ul class="divide-y divide-stone-200/70 dark:divide-stone-800">
              {
                posts.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE).map((post) => (
                  <li>
                    <a
                      href={`/${post.data.slug || post.id}`}
                      class="group grid gap-4 py-4 transition-colors sm:grid-cols-[128px_1fr] sm:items-center"
                    >
                      {post.data.cover ? (
                        <span class="cover-frame block h-24 sm:h-20">
                          <img
                            src={post.data.cover}
                            alt=""
                            class="cover-image h-full group-hover:opacity-90"
                            loading="lazy"
                            decoding="async"
                          />
                        </span>
                      ) : (
                        <div class="flex h-24 w-full items-center justify-center rounded-lg border border-stone-200/70 bg-stone-100/60 text-stone-400 sm:h-20 dark:border-stone-800 dark:bg-stone-900/70">
                          <svg
                            class="h-7 w-7"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            aria-hidden="true"
                          >
                            <path d="M4 19.5V5a2 2 0 0 1 2-2h12v18H6a2 2 0 0 1-2-1.5Z" />
                            <path d="M8 7h7" />
                            <path d="M8 11h8" />
                          </svg>
                        </div>
                      )}
                      <div class="min-w-0">
                        <div class="flex items-start gap-2">
                          <h3 class="line-clamp-2 flex-1 text-base leading-snug font-semibold text-stone-800 transition-colors group-hover:text-stone-950 dark:text-stone-200 dark:group-hover:text-stone-50">
                            {post.data.title}
                            <span
                              class="ml-1.5 inline-flex translate-x-[-3px] align-[-2px] text-stone-400 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 motion-safe:transition-[opacity,translate] motion-safe:duration-200 motion-safe:ease-out dark:text-stone-500"
                              aria-hidden="true"
                            >
                              <svg
                                class="h-3.5 w-3.5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M5 12h14" />
                                <path d="m13 6 6 6-6 6" />
                              </svg>
                            </span>
                          </h3>
                          {showDraftPosts && post.data.draft && (
                            <span class="mt-0.5 rounded border border-rose-200 bg-rose-50 px-1.5 py-0.5 text-[10px] font-medium text-rose-500 dark:border-rose-900/60 dark:bg-rose-950/30 dark:text-rose-300">
                              草稿
                            </span>
                          )}
                        </div>
                        {post.data.description && (
                          <p class="mt-1 line-clamp-1 text-sm text-stone-500 dark:text-stone-400">
                            {post.data.description}
                          </p>
                        )}
                        <div class="mt-2 flex items-center gap-2 font-mono text-xs text-stone-400 dark:text-stone-500">
                          <span>{formatDate(post.data.date)}</span>
                          <span>·</span>
                          <span>{readingTime(post.body ?? '')}</span>
                        </div>
                      </div>
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>

          <section class="ink-card home-panel hidden p-5 sm:block sm:p-6">
            <div class="mb-4">
              <h2
                class="text-lg font-semibold text-stone-900 dark:text-stone-100"
              >
                内容统计
              </h2>
            </div>
            <div
              class="grid grid-cols-2 divide-x divide-stone-200/70 dark:divide-stone-800"
            >
              <a
                href="/posts"
                class="group pr-5 transition-colors"
                aria-label={`查看 ${posts.length} 篇文章`}
              >
                <span
                  class="inline-flex items-center text-sm text-stone-500 dark:text-stone-400"
                >
                  文章
                  <span
                    class="ml-1 inline-flex translate-x-[-3px] opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 motion-safe:transition-[opacity,translate] motion-safe:duration-200 motion-safe:ease-out"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </span>
                <span
                  class="mt-2 block text-3xl leading-none font-semibold text-stone-900 transition-colors group-hover:text-stone-950 dark:text-stone-100 dark:group-hover:text-stone-50"
                >
                  {posts.length}
                </span>
                <span
                  class="mt-2 block text-xs text-stone-400 dark:text-stone-500"
                >
                  篇公开文章
                </span>
              </a>
              <a
                href="/thoughts"
                class="group pl-5 transition-colors"
                aria-label={`查看 ${thoughts.length} 条碎碎念`}
              >
                <span
                  class="inline-flex items-center text-sm text-stone-500 dark:text-stone-400"
                >
                  碎碎念
                  <span
                    class="ml-1 inline-flex translate-x-[-3px] opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 motion-safe:transition-[opacity,translate] motion-safe:duration-200 motion-safe:ease-out"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </span>
                <span
                  class="mt-2 block text-3xl leading-none font-semibold text-stone-900 transition-colors group-hover:text-stone-950 dark:text-stone-100 dark:group-hover:text-stone-50"
                >
                  {thoughts.length}
                </span>
                <span
                  class="mt-2 block text-xs text-stone-400 dark:text-stone-500"
                >
                  条生活流
                </span>
              </a>
            </div>
          </section>
        </div>

        <div class="flex h-full flex-col gap-6">
          {
            thoughts.length > 0 && (
              <section class="ink-card home-panel flex-1 p-5 sm:p-6">
                <div class="mb-4 flex items-center justify-between gap-3">
                  <h2 class="text-lg font-semibold text-stone-900 dark:text-stone-100">
                    最近动态 / 碎碎念
                  </h2>
                </div>
                <div class="space-y-3">
                  {thoughts
                    .slice(0, SITE.NUM_THOUGHTS_ON_HOMEPAGE + 2)
                    .map((thought, index) => {
                      const thoughtId = thoughts.length - index
                      const preview = extractPlainText(thought.body ?? '')
                      return (
                        <a
                          href={`/thoughts#${thoughtId}`}
                          class="group grid grid-cols-[auto_1fr] gap-3 rounded-lg px-2 py-2 transition-colors hover:bg-stone-100/55 dark:hover:bg-stone-800/55"
                        >
                          <span
                            class={`mt-1 h-2.5 w-2.5 rounded-full ${accentClasses[index % accentClasses.length]}`}
                          />
                          <span class="min-w-0">
                            <span class="flex items-center gap-2 text-xs">
                              <span class="font-mono font-semibold text-stone-700 dark:text-stone-300">
                                #{thoughtId}
                              </span>
                              <span
                                class="time-ago text-stone-400 dark:text-stone-500"
                                data-timestamp={thought.data.date.getTime()}
                              >
                                {timeAgo(thought.data.date)}
                              </span>
                            </span>
                            <span class="mt-1 line-clamp-2 block text-sm leading-relaxed text-stone-600 group-hover:text-stone-900 dark:text-stone-300 dark:group-hover:text-stone-100">
                              {preview}
                            </span>
                          </span>
                        </a>
                      )
                    })}
                </div>
                <Link
                  href="/thoughts"
                  underline={false}
                  class="mt-4 inline-flex text-sm text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
                >
                  查看全部碎碎念 →
                </Link>
              </section>
            )
          }

          <section class="ink-card home-panel p-5 sm:p-6">
            <div class="mb-4 flex items-baseline justify-between gap-3">
              <h2
                class="text-lg font-semibold text-stone-900 dark:text-stone-100"
              >
                模板能力
              </h2>
              <span class="font-mono text-xs text-stone-400">Features</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {
                featureItems.map((item) => (
                  <span class="rounded-md border border-stone-200/70 bg-white/45 px-2.5 py-1.5 text-xs text-stone-600 dark:border-stone-800 dark:bg-stone-900/45 dark:text-stone-300">
                    {item}
                  </span>
                ))
              }
            </div>
            <p
              class="mt-4 text-sm leading-7 text-stone-500 dark:text-stone-400"
            >
              先替换配置和示例内容，再按 README 选择是否启用 GitHub Issues
              评论、点赞和在线发布。
            </p>
          </section>
        </div>
      </div>
    </div>
  </Container>
</PageLayout>

<script>
  import { setupTimeAgo } from '@lib/timeago-client'

  function init() {
    setupTimeAgo()
  }

  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:after-swap', init)

  if (document.readyState === 'complete') {
    init()
  }
</script>

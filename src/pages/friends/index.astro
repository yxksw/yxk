---
import Container from '@components/Container.astro'
import Link from '@components/Link.astro'
import { SITE } from '@consts'
import PageLayout from '@layouts/PageLayout.astro'

const FRIENDS_META = {
  TITLE: '友链',
  DESCRIPTION: '我的朋友们',
}

const FRIENDS = [
  {
    name: 'Dogxi 的狗窝',
    href: 'https://blog.dogxi.me',
    desc: 'Dogxi 的个人博客，因为热爱所以热爱。',
    avatar: 'https://blog.dogxi.me/avatar.png',
    rss: 'https://blog.dogxi.me/rss.xml',
  },
  {
    name: 'Astro',
    href: 'https://astro.build',
    desc: 'The web framework for content-driven websites.',
    avatar: 'https://astro.build/favicon.svg',
    rss: 'https://astro.build/rss.xml',
  },
  {
    name: 'Tailwind CSS',
    href: 'https://tailwindcss.com',
    desc: 'Rapidly build modern websites without leaving your HTML.',
    avatar: 'https://tailwindcss.com/favicons/favicon-32x32.png',
    rss: 'https://tailwindcss.com/blog/rss.xml',
  },
]

// 我的博客信息（用于友链交换）
const siteUrl =
  Astro.site?.toString().replace(/\/$/, '') || 'https://example.com'
const MY_SITE = {
  name: SITE.NAME,
  url: siteUrl,
  desc: SITE.DESCRIPTION,
  avatar: `${siteUrl}/avatar.png`,
  rss: `${siteUrl}/rss.xml`,
}
---

<PageLayout title={FRIENDS_META.TITLE} description={FRIENDS_META.DESCRIPTION}>
  <Container class="!max-w-3xl">
    <section class="py-4">
      <h1
        class="text-3xl font-semibold text-stone-950 sm:text-4xl dark:text-stone-50"
      >
        友链
      </h1>
      <p
        class="mt-3 max-w-2xl leading-relaxed text-stone-600 dark:text-stone-400"
      >
        一些有趣的朋友们，互相交流，共同成长
      </p>
    </section>
    <div class="mt-8 space-y-10">
      <!-- 友链列表 -->
      <section class="animate">
        <ul
          id="friends-list"
          class="grid grid-cols-1 gap-2 sm:grid-cols-2 sm:gap-3"
        >
          {
            FRIENDS.map((friend) => (
              <li class="group relative flex items-center overflow-hidden rounded-lg border border-stone-200/45 bg-transparent p-3 transition-colors duration-200 hover:bg-stone-50/65 dark:border-stone-800/60 dark:hover:bg-stone-900/28">
                <div class="mr-3 ml-1 h-9 w-9 shrink-0">
                  <img
                    src={friend.avatar}
                    alt={`${friend.name} Avatar`}
                    class="h-full w-full rounded-full object-cover transition-transform duration-200 group-hover:scale-[1.04]"
                    loading="lazy"
                    decoding="async"
                    width="40"
                    height="40"
                  />
                </div>

                <div class="flex min-w-0 flex-col transition-transform duration-300 group-hover:translate-x-0">
                  <div class="font-medium text-stone-800 transition-colors group-hover:text-stone-950 dark:text-stone-200 dark:group-hover:text-stone-50">
                    {friend.name}
                  </div>
                  <div class="line-clamp-1 text-sm text-stone-500 transition-colors group-hover:text-stone-700 dark:text-stone-500 dark:group-hover:text-stone-300">
                    {friend.desc}
                  </div>
                </div>

                {/* 整卡片可点击 */}
                <a
                  href={friend.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="absolute inset-0 z-10"
                  aria-label={friend.name}
                />
              </li>
            ))
          }
        </ul>
      </section>

      <!-- 申请友链 (折叠) -->
      <section class="animate">
        <details
          class="group rounded-lg border border-stone-200/45 bg-transparent dark:border-stone-800/65"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between px-3 py-3 font-medium text-stone-800 transition-colors hover:bg-stone-50/65 dark:text-stone-200 dark:hover:bg-stone-900/35"
          >
            <span class="text-lg font-semibold">申请友链</span>
            <span
              class="transition-transform duration-300 group-open:rotate-180"
            >
              <svg
                class="h-5 w-5 text-stone-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M6 9l6 6 6-6"></path>
              </svg>
            </span>
          </summary>

          <div
            class="border-t border-stone-200/45 px-4 pt-4 pb-6 sm:px-6 dark:border-stone-800/65"
          >
            <p class="mb-4 text-stone-600 dark:text-stone-400">
              欢迎交换友链！请确保你的网站符合以下条件：
            </p>
            <ul
              class="mb-6 space-y-2 text-sm text-stone-600 dark:text-stone-400"
            >
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-green-500">✓</span>
                <span>网站内容积极向上，无违法违规内容</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-green-500">✓</span>
                <span>网站能够正常访问，有一定的原创内容</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-0.5 text-green-500">✓</span>
                <span>已添加本站友链</span>
              </li>
            </ul>

            <div class="space-y-4">
              <h3
                class="text-sm font-medium text-stone-700 dark:text-stone-300"
              >
                本站信息
              </h3>
              <div
                class="overflow-hidden rounded-lg border border-stone-200/60 bg-white/45 dark:border-stone-800 dark:bg-stone-900/40"
              >
                <div
                  class="flex items-center justify-between border-b border-stone-200/60 px-4 py-2 dark:border-stone-800"
                >
                  <span class="text-xs text-stone-500 dark:text-stone-400"
                    >友链信息</span
                  >
                  <button
                    type="button"
                    id="copy-info"
                    class="flex items-center gap-1 rounded px-2 py-1 text-xs text-stone-500 transition-colors hover:bg-stone-100 hover:text-stone-700 dark:text-stone-400 dark:hover:bg-stone-700 dark:hover:text-stone-200"
                  >
                    <svg
                      class="h-3.5 w-3.5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                      ></rect>
                      <path
                        d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                      ></path>
                    </svg>
                    复制
                  </button>
                </div>
                <pre
                  id="site-info"
                  class="overflow-x-auto p-4 text-xs text-stone-700 dark:text-stone-300"><code>{`名称：${MY_SITE.name}
链接：${MY_SITE.url}
描述：${MY_SITE.desc}
头像：${MY_SITE.avatar}
RSS：${MY_SITE.rss}`}</code></pre>
              </div>
            </div>

            <div class="mt-6">
              <p class="text-sm text-stone-600 dark:text-stone-400">
                请将你的友链信息通过以下方式发送给我：
              </p>
              <div class="mt-3 flex flex-wrap gap-3">
                <Link
                  href={`mailto:${SITE.EMAIL}?subject=友链申请&body=名称：%0A链接：%0A描述：%0A头像：%0ARSS（可选）：`}
                  class="inline-flex items-center gap-2 rounded-lg border border-stone-200/60 bg-white/45 px-4 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 dark:border-stone-800 dark:bg-stone-900/40 dark:text-stone-300 dark:hover:bg-stone-900"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                  发送邮件
                </Link>
                <Link
                  href="https://github.com/username/blog/issues"
                  external
                  class="inline-flex items-center gap-2 rounded-lg border border-stone-200/60 bg-white/45 px-4 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 dark:border-stone-800 dark:bg-stone-900/40 dark:text-stone-300 dark:hover:bg-stone-900"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path
                      d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path>
                  </svg>
                  GitHub Issue
                </Link>
              </div>
            </div>
          </div>
        </details>
      </section>
    </div>
  </Container>
</PageLayout>

<!-- Toast -->
<div
  id="copy-toast"
  class="pointer-events-none fixed bottom-8 left-1/2 z-50 -translate-x-1/2 transform opacity-0 transition-all duration-300"
>
  <div
    class="rounded-lg bg-stone-800 px-4 py-2 text-sm text-white shadow-lg dark:bg-stone-200 dark:text-stone-800"
  >
    ✓ 已复制到剪贴板
  </div>
</div>

<script>
  function shuffleFriendList() {
    const list = document.getElementById('friends-list')
    if (!list) return

    const items = Array.from(list.children)
    for (let index = items.length - 1; index > 0; index -= 1) {
      const randomIndex = Math.floor(Math.random() * (index + 1))
      const currentItem = items[index]
      items[index] = items[randomIndex]
      items[randomIndex] = currentItem
    }

    list.replaceChildren(...items)
  }

  function setupCopy() {
    const copyBtn = document.getElementById('copy-info')
    const siteInfo = document.getElementById('site-info')
    const toast = document.getElementById('copy-toast')

    if (!copyBtn || !siteInfo || !toast) return
    if (copyBtn.dataset.copyBound === 'true') return
    copyBtn.dataset.copyBound = 'true'

    copyBtn.addEventListener('click', async () => {
      const text = siteInfo.textContent || ''
      try {
        await navigator.clipboard.writeText(text)
        toast.classList.remove('opacity-0')
        toast.classList.add('opacity-100')
        setTimeout(() => {
          toast.classList.remove('opacity-100')
          toast.classList.add('opacity-0')
        }, 2000)
      } catch (e) {
        console.error('Failed to copy:', e)
      }
    })
  }

  shuffleFriendList()
  setupCopy()
  document.addEventListener('astro:after-swap', () => {
    shuffleFriendList()
    setupCopy()
  })
</script>

{
  "name": "astro-doge",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "version": "1.2.0",
  "description": "A static-first Astro blog template with posts, thoughts, albums, search, PWA, and optional Vercel-ready GitHub-powered comments, likes, and publishing.",
  "license": "MIT",
  "homepage": "https://github.com/dogxii/astro-doge",
  "repository": {
    "type": "git",
    "url": "https://github.com/dogxii/astro-doge.git"
  },
  "bugs": {
    "url": "https://github.com/dogxii/astro-doge/issues"
  },
  "keywords": [
    "astro",
    "blog",
    "template",
    "theme",
    "tailwindcss",
    "mdx",
    "pwa"
  ],
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host",
    "build": "rm -rf .astro node_modules/.vite && astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro preview --host",
    "astro": "astro",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "new:blog": "bun run scripts/new-blog.ts",
    "new:thought": "bun run scripts/new-thought.ts",
    "new": "bun run scripts/new-blog.ts",
    "t": "bun run scripts/new-thought.ts",
    "pwa:icons": "bun run scripts/generate-pwa-icons.ts",
    "pwa:check": "bun run scripts/check-pwa.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vercel/node": "^5.7.10",
    "astro": "^6.3.3",
    "astro-expressive-code": "^0.41.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
